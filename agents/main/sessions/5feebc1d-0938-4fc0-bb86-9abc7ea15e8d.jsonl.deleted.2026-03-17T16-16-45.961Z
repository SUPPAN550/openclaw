{"type":"message","id":"99301309","parentId":"79dcd0c6","timestamp":"2026-03-17T15:30:28.893Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"write:16","name":"write","arguments":{"content":"import { useState } from 'react'\nimport {\n  Settings,\n  User,\n  Bell,\n  Shield,\n  Database,\n  Globe,\n  Palette,\n  Key,\n  CreditCard,\n  Users,\n  Save,\n  ChevronRight,\n  Moon,\n  Sun,\n  Monitor,\n  Check,\n  AlertCircle\n} from 'lucide-react'\n\nconst settingsSections = [\n  { id: 'profile', label: '个人资料', icon: User, description: '管理您的账户信息和头像' },\n  { id: 'notifications', label: '通知设置', icon: Bell, description: '配置消息和邮件通知' },\n  { id: 'security', label: '安全设置', icon: Shield, description: '密码、双因素认证和登录历史' },\n  { id: 'api', label: 'API 密钥', icon: Key, description: '管理 API 访问密钥和权限' },\n  { id: 'billing', label: '账单', icon: CreditCard, description: '查看账单历史和支付方式' },\n  { id: 'team', label: '团队管理', icon: Users, description: '管理团队成员和权限' },\n  { id: 'database', label: '数据存储', icon: Database, description: '备份、导出和数据管理' },\n  { id: 'appearance', label: '外观', icon: Palette, description: '主题、语言和界面设置' },\n]\n\nexport default function SettingsPage() {\n  const [activeSection, setActiveSection] = useState('profile')\n  const [theme, setTheme] = useState('dark')\n  const [language, setLanguage] = useState('zh-CN')\n  const [notifications, setNotifications] = useState({\n    email: true,\n    push: true,\n    sms: false,\n    marketing: false,\n  })\n\n  return (\n    <div className=\"space-y-6\">\n      {/* Header */}\n      <div>\n        <h1 className=\"text-2xl font-bold text-white\">设置 Settings</h1>\n        <p className=\"text-dark-400 mt-1\">管理您的账户和系统偏好设置</p>\n      </div>\n\n      <div className=\"flex gap-6\">\n        {/* Sidebar */}\n        <aside className=\"w-72 flex-shrink-0 space-y-1\">\n          {settingsSections.map((section) => {\n            const Icon = section.icon\n            return (\n              <button\n                key={section.id}\n                onClick={() => setActiveSection(section.id)}\n                className={`w-full flex items-start gap-3 px-4 py-3 rounded-xl text-left transition-colors ${\n                  activeSection === section.id\n                    ? 'bg-primary-600/10 border border-primary-600/20'\n                    : 'hover:bg-dark-800'\n                }`}\n              >\n                <div className={`p-2 rounded-lg ${\n                  activeSection === section.id ? 'bg-primary-600/20' : 'bg-dark-800'\n                }`}>\n                  <Icon className={`w-4 h-4 ${\n                    activeSection === section.id ? 'text-primary-400' : 'text-dark-400'\n                  }`} />\n                </div>\n                <div className=\"flex-1\">\n                  <p className={`font-medium text-sm ${\n                    activeSection === section.id ? 'text-primary-400' : 'text-white'\n                  }`}>\n                    {section.label}\n                  </p>\n                  <p className=\"text-dark-500 text-xs mt-0.5\">{section.description}</p>\n                </div>\n                <ChevronRight className={`w-4 h-4 mt-1 transition-transform ${\n                  activeSection === section.id ? 'text-primary-400 rotate-90' : 'text-dark-600'\n                }`} />\n              </button>\n            )\n          })}\n        </aside>\n\n        {/* Content */}\n        <div className=\"flex-1\">\n          {/* Profile Section */}\n          {activeSection === 'profile' && (\n            <div className=\"bg-dark-900 border border-dark-800 rounded-xl p-6 space-y-6\">\n              <div>\n                <h2 className=\"text-lg font-semibold text-white\">个人资料</h2>\n                <p className=\"text-dark-400 text-sm\">更新您的个人信息和头像</p>\n              </div>\n\n              {/* Avatar */}\n              <div className=\"flex items-center gap-4\">\n                <div className=\"w-20 h-20 bg-gradient-to-br from-primary-500 to-purple-600 rounded-full flex items-center justify-center\">\n                  <span className=\"text-white text-2xl font-semibold\">S</span>\n                </div>\n                <div>\n                  <button className=\"px-4 py-2 bg-dark-800 hover:bg-dark-700 text-white rounded-lg text-sm transition-colors\">\n                    更换头像\n                  </button>\n                  <p className=\"text-dark-500 text-xs mt-2\">支持 JPG、PNG 格式，最大 2MB</p>\n                </div>\n              </div>\n\n              {/* Form */}\n              <div className=\"grid grid-cols-2 gap-4\">\n                <div>\n                  <label className=\"block text-sm text-dark-300 mb-2\">显示名称</label>\n                  <input\n                    type=\"text\"\n                    defaultValue=\"Sir\"\n                    className=\"w-full bg-dark-800 border border-dark-700 rounded-lg px-4 py-2.5 text-white text-sm focus:outline-none focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500/50\"\n                  />\n                </div>\n                <div>\n                  <label className=\"block text-sm text-dark-300 mb-2\">用户名</label>\n                  <input\n                    type=\"text\"\n                    defaultValue=\"sir_admin\"\n                    disabled\n                    className=\"w-full bg-dark-800/50 border border-dark-700 rounded-lg px-4 py-2.5 text-dark-400 text-sm cursor-not-allowed\"\n                  />\n                </div>\n                <div>\n                  <label className=\"block text-sm text-dark-300 mb-2\">邮箱</label>\n                  <input\n                    type=\"email\"\n                    defaultValue=\"sir@example.com\"\n                    className=\"w-full bg-dark-800 border border-dark-700 rounded-lg px-4 py-2.5 text-white text-sm focus:outline-none focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500/50\"\n                  />\n                </div>\n                <div>\n                  <label className=\"block text-sm text-dark-300 mb-2\">电话</label>\n                  <input\n                    type=\"tel\"\n                    defaultValue=\"+86 138****8888\"\n                    className=\"w-full bg-dark-800 border border-dark-700 rounded-lg px-4 py-2.5 text-white text-sm focus:outline-none focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500/50\"\n                  />\n                </div>\n              </div>\n\n              <div className=\"flex justify-end\">\n                <button className=\"flex items-center gap-2 bg-primary-600 hover:bg-primary-700 text-white px-4 py-2 rounded-lg transition-colors\">\n                  <Save className=\"w-4 h-4\" />\n                  <span>保存更改</span>\n                </button>\n              </div>\n            </div>\n          )}\n\n          {/* Notifications Section */}\n          {activeSection === 'notifications' && (\n            <div className=\"bg-dark-900 border border-dark-800 rounded-xl p-6 space-y-6\">\n              <div>\n                <h2 className=\"text-lg font-semibold text-white\">通知设置</h2>\n                <p className=\"text-dark-400 text-sm\">选择您希望接收的通知类型</p>\n              </div>\n\n              <div className=\"space-y-4\">\n                {[\n                  { id: 'email', label: '邮件通知', description: '接收重要更新和报告' },\n                  { id: 'push', label: '推送通知', description: '浏览器和桌面推送' },\n                  { id: 'sms', label: '短信通知', description: '紧急情况的短信提醒' },\n                  { id: 'marketing', label: '营销邮件', description: '产品更新和优惠信息' },\n                ].map((item) => (\n                  <div\n                    key={item.id}\n                    className=\"flex items-center justify-between p-4 bg-dark-800/50 rounded-xl\"\n                  >\n                    <div>\n                      <p className=\"text-white font-medium\">{item.label}</p>\n                      <p className=\"text-dark-400 text-sm\">{item.description}</p>\n                    </div>\n                    <button\n                      onClick={() => setNotifications((prev) => ({ ...prev, [item.id]: !prev[item.id as keyof typeof notifications] }))}\n                      className={`w-12 h-6 rounded-full transition-colors relative ${\n                        notifications[item.id as keyof typeof notifications] ? 'bg-primary-600' : 'bg-dark-700'\n                      }`}\n                    >\n                      <span\n                        className={`absolute top-1 w-4 h-4 bg-white rounded-full transition-transform ${\n                          notifications[item.id as keyof typeof notifications] ? 'left-7' : 'left-1'\n                        }`}\n                      />\n                    </button>\n                  </div>\n                ))}\n              </div>\n            </div>\n          )}\n\n          {/* Security Section */}\n          {activeSection === 'security' && (\n            <div className=\"bg-dark-900 border border-dark-800 rounded-xl p-6 space-y-6\">\n              <div>\n                <h2 className=\"text-lg font-semibold text-white\">安全设置</h2>\n                <p className=\"text-dark-400 text-sm\">保护您的账户安全</p>\n              </div>\n\n              <div className=\"space-y-4\">\n                <div className=\"p-4 bg-dark-800/50 rounded-xl\">\n                  <div className=\"flex items-center justify-between mb-4\">\n                    <div>\n                      <p className=\"text-white font-medium\">密码</p>\n                      <p className=\"text-dark-400 text-sm\">上次更改：3个月前</p>\n                    </div>\n                    <button className=\"px-4 py-2 bg-dark-800 hover:bg-dark-700 text-white rounded-lg text-sm transition-colors\">\n                      修改密码\n                    </button>\n                  </div>\n                </div>\n\n                <div className=\"p-4 bg-dark-800/50 rounded-xl\">\n                  <div className=\"flex items-center justify-between\">\n                    <div>\n                      <p className=\"text-white font-medium\">双因素认证 (2FA)</p>\n                      <p className=\"text-dark-400 text-sm\">使用身份验证器应用增强安全性</p>\n                    </div>\n                    <button className=\"px-4 py-2 bg-green-600/20 text-green-400 rounded-lg text-sm flex items-center gap-2\">\n                      <Check className=\"w-4 h-4\" />\n                      已启用\n                    </button>\n                  </div>\n                </div>\n\n                <div className=\"p-4 bg-dark-800/50 rounded-xl\">\n                  <div className=\"flex items-center justify-between\">\n                    <div>\n                      <p className=\"text-white font-medium\">登录历史</p>\n                      <p className=\"text-dark-400 text-sm\">查看最近的登录活动</p>\n                    </div>\n                    <button className=\"px-4 py-2 bg-dark-800 hover:bg-dark-700 text-white rounded-lg text-sm transition-colors\">\n                      查看详情\n                    </button>\n                  </div>\n                </div>\n              </div>\n            </div>\n          )}\n\n          {/* Appearance Section */}\n          {activeSection === 'appearance' && (\n            <div className=\"bg-dark-900 border border-dark-800 rounded-xl p-6 space-y-6\">\n              <div>\n                <h2 className=\"text-lg font-semibold text-white\">外观</h2>\n                <p className=\"text-dark-400 text-sm\">自定义界面主题和语言</p>\n              </div>\n\n              {/* Theme */}\n              <div>\n                <label className=\"block text-sm text-dark-300 mb-3\">主题</label>\n                <div className=\"grid grid-cols-3 gap-3\">\n                  {[\n                    { id: 'light', label: '浅色', icon: Sun },\n                    { id: 'dark', label: '深色', icon: Moon },\n                    { id: 'system', label: '跟随系统', icon: Monitor },\n                  ].map((t) => {\n                    const Icon = t.icon\n                    return (\n                      <button\n                        key={t.id}\n                        onClick={() => setTheme(t.id)}\n                        className={`p-4 rounded-xl border transition-all ${\n                          theme === t.id\n                            ? 'bg-primary-600/10 border-primary-600/50'\n                            : 'bg-dark-800 border-dark-700 hover:border-dark-600'\n                        }`}\n                      >\n                        <Icon className={`w-6 h-6 mx-auto mb-2 ${\n                          theme === t.id ? 'text-primary-400' : 'text-dark-400'\n                        }`} />\n                        <p className={`text-sm ${theme === t.id ? 'text-primary-400' : 'text-dark-300'}`}>\n                          {t.label}\n                        </p>\n                      </button>\n                    )\n                  })}\n                </div>\n              </div>\n\n              {/* Language */}\n              <div>\n                <label className=\"block text-sm text-dark-300 mb-3\">语言</label>\n                <select\n                  value={language}\n                  onChange={(e) => setLanguage(e.target.value)}\n                  className=\"w-full bg-dark-800 border border-dark-700 rounded-lg px-4 py-2.5 text-white text-sm focus:outline-none focus:ring-2 focus:ring-primary-500/20\"\n                >\n                  <option value=\"zh-CN\">简体中文</option>\n                  <option value=\"zh-TW\">繁體中文</option>\n                  <option value=\"en-US\">English</option>\n                  <option value=\"ja-JP\">日本語</option>\n                </select>\n              </div>\n            </div>\n          )}\n\n          {/* Other Sections Placeholder */}\n          {['api', 'billing', 'team', 'database'].includes(activeSection) && (\n            <div className=\"bg-dark-900 border border-dark-800 rounded-xl p-6\">\n              <div className=\"flex items-center gap-3 text-dark-400\">\n                <AlertCircle className=\"w-5 h-5\" />\n                <p>此功能正在开发中，敬请期待...</p>\n              </div>\n            </div>\n          )}\n        </div>\n      </div>\n    </div>\n  )\n}","file_path":"C:/Users/Administrator/.openclaw/workspace/control-center/src/pages/Settings.tsx"}}],"api":"openai-completions","provider":"moonshot","model":"kimi-k2.5","usage":{"input":1548,"output":3559,"cacheRead":58112,"cacheWrite":0,"totalTokens":63219,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773761329451}}
