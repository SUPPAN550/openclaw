y\",\n        \"type\": \"array\",\n        \"required\": false,\n        \"hasChildren\": true,\n        \"hint\": {\n          \"label\": \"Plugin Denylist\",\n          \"help\": \"Optional denylist of plugin IDs that are blocked even if allowlists or paths include them. Use deny rules for emergency rollback and hard blocks on risky plugins.\",\n          \"tags\": [\n            \"access\"\n          ]\n        },\n        \"hintPath\": \"plugins.deny\"\n      },\n      {\n        \"key\": \"load\",\n        \"path\": \"plugins.load\",\n        \"type\": \"object\",\n        \"required\": false,\n        \"hasChildren\": true,\n        \"hint\": {\n          \"label\": \"Plugin Loader\",\n          \"help\": \"Plugin loader configuration group for specifying filesystem paths where plugins are discovered. Keep load paths explicit and reviewed to avoid accidental untrusted extension loading.\",\n          \"tags\": [\n            \"advanced\"\n          ]\n        },\n        \"hintPath\": \"plugins.load\"\n      },\n      {\n        \"key\": \"slots\",\n        \"path\": \"plugins.slots\",\n        \"type\": \"object\",\n        \"required\": false,\n        \"hasChildren\": true,\n        \"hint\": {\n          \"label\": \"Plugin Slots\",\n          \"help\": \"Selects which plugins own exclusive runtime slots such as memory so only one plugin provides that capability. Use explicit slot ownership to avoid overlapping providers with conflicting behavior.\",\n          \"tags\": [\n            \"advanced\"\n          ]\n        },\n        \"hintPath\": \"plugins.slots\"\n      },\n      {\n        \"key\": \"entries\",\n        \"path\": \"plugins.entries\",\n        \"type\": \"object\",\n        \"required\": false,\n        \"hasChildren\": true,\n        \"hint\": {\n          \"label\": \"Plugin Entries\",\n          \"help\": \"Per-plugin settings keyed by plugin ID including enablement and plugin-specific runtime configuration payloads. Use this for scoped plugin tuning without changing global loader policy.\",\n          \"tags\": [\n            \"advanced\"\n          ]\n        },\n        \"hintPath\": \"plugins.entries\"\n      },\n      {\n        \"key\": \"installs\",\n        \"path\": \"plugins.installs\",\n        \"type\": \"object\",\n        \"required\": false,\n        \"hasChildren\": true,\n        \"hint\": {\n          \"label\": \"Plugin Install Records\",\n          \"help\": \"CLI-managed install metadata (used by `openclaw plugins update` to locate install sources).\",\n          \"tags\": [\n            \"advanced\"\n          ]\n        },\n        \"hintPath\": \"plugins.installs\"\n      }\n    ]\n  }\n}"}],"details":{"ok":true,"result":{"path":"plugins","schema":{"type":"object","additionalProperties":false},"hint":{"label":"Plugins","group":"Plugins","order":205,"help":"Plugin system controls for enabling extensions, constraining load scope, configuring entries, and tracking installs. Keep plugin policy explicit and least-privilege in production environments.","tags":["advanced"]},"hintPath":"plugins","children":[{"key":"enabled","path":"plugins.enabled","type":"boolean","required":false,"hasChildren":false,"hint":{"label":"Enable Plugins","help":"Enable or disable plugin/extension loading globally during startup and config reload (default: true). Keep enabled only when extension capabilities are required by your deployment.","tags":["advanced"]},"hintPath":"plugins.enabled"},{"key":"allow","path":"plugins.allow","type":"array","required":false,"hasChildren":true,"hint":{"label":"Plugin Allowlist","help":"Optional allowlist of plugin IDs; when set, only listed plugins are eligible to load. Use this to enforce approved extension inventories in controlled environments.","tags":["access"]},"hintPath":"plugins.allow"},{"key":"deny","path":"plugins.deny","type":"array","required":false,"hasChildren":true,"hint":{"label":"Plugin Denylist","help":"Optional denylist of plugin IDs that are block