ions:\n        return jsonify({\n            \"success\": False,\n            \"error\": f\"Invalid action. Valid actions: {', '.join(valid_actions)}\"\n        }), 400\n    \n    try:\n        if action == \"chat\":\n            # 与 Agent 对话 - 使用 openclaw agent 命令\n            cmd = f\"openclaw agent --agent {agent_id} -m \\\"Hello from Hub\\\" --json\"\n            stdout, stderr, returncode = run_command(cmd)\n            \n            if returncode == 0:\n                return jsonify({\n                    \"success\": True,\n                    \"message\": f\"Agent {agent_id} 对话已启动\",\n                    \"output\": stdout\n                })\n            else:\n                return jsonify({\n                    \"success\": False,\n                    \"error\": stderr or stdout,\n                    \"returncode\": returncode\n                }), 500\n        else:\n            # start/stop/restart - OpenClaw 没有直接的 agent 管理命令\n            # 返回提示信息，实际功能通过配置管理\n            return jsonify({\n                \"success\": True,\n                \"message\": f\"Agent {agent_id} {action} 操作已记录（OpenClaw Agent 是状态less的，通过配置切换）\",\n                \"note\": \"OpenClaw 的 Agent 通过配置文件管理，而非进程管理\"\n            })\n            \n    except Exception as e:\n        return jsonify({\n            \"success\": False,\n            \"error\": str(e)\n        }), 500"}}],"api":"openai-completions","provider":"moonshot","model":"kimi-k2.5","usage":{"input":836,"output":853,"cacheRead":64256,"cacheWrite":0,"totalTokens":65945,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773718761482}}
