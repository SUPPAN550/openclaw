"lastRunStatus\": \"ok\",\n        \"lastStatus\": \"ok\",\n        \"lastDurationMs\": 21879,\n        \"lastDeliveryStatus\": \"not-requested\",\n        \"consecutiveErrors\": 0\n      }\n    },\n    {\n      \"id\": \"07780d7d-3430-46aa-8819-9030f1c25cb8\",\n      \"agentId\": \"main\",\n      \"sessionKey\": \"agent:main:main\",\n      \"name\": \"Otter: 日程提醒检查\",\n      \"enabled\": true,\n      \"createdAtMs\": 1773760308101,\n      \"updatedAtMs\": 1773788422054,\n      \"schedule\": {\n        \"kind\": \"cron\",\n        \"expr\": \"0 7 * * *\",\n        \"tz\": \"Asia/Shanghai\"\n      },\n      \"sessionTarget\": \"isolated\",\n      \"wakeMode\": \"now\",\n      \"payload\": {\n        \"kind\": \"agentTurn\",\n        \"message\": \"你是 Otter（私人助理），检查今天的飞书日历和任务：\\n1. 获取今日日程\\n2. 列出待办事项\\n3. 发送今日行程概览给用户\"\n      },\n      \"delivery\": {\n        \"mode\": \"announce\"\n      },\n      \"state\": {\n        \"nextRunAtMs\": 1773874800000,\n        \"lastRunAtMs\": 1773788400009,\n        \"lastRunStatus\": \"error\",\n        \"lastStatus\": \"error\",\n        \"lastDurationMs\": 22045,\n        \"lastError\": \"AxiosError: Request failed with status code 400\",\n        \"lastDeliveryStatus\": \"unknown\",\n        \"consecutiveErrors\": 1\n      }\n    },\n    {\n      \"id\": \"1be3234d-b25c-4860-94ca-411343a4a3e9\",\n      \"agentId\": \"main\",\n      \"sessionKey\": \"agent:main:main\",\n      \"name\": \"Gock: 早间新闻简报\",\n      \"enabled\": true,\n      \"createdAtMs\": 1773760308080,\n      \"updatedAtMs\": 1773792022609,\n      \"schedule\": {\n        \"kind\": \"cron\",\n        \"expr\": \"0 8 * * *\",\n        \"tz\": \"Asia/Shanghai\"\n      },\n      \"sessionTarget\": \"isolated\",\n      \"wakeMode\": \"now\",\n      \"payload\": {\n        \"kind\": \"agentTurn\",\n        \"message\": \"你是 Gock（每日新闻），使用 news-summary skill 获取今日新闻，生成一份简洁的早间新闻简报（科技、财经、国际要点），发送给用户\"\n      },\n      \"delivery\": {\n        \"mode\": \"announce\"\n      },