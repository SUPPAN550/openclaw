cal-test-token-123\"}},\n]\n\nfor i, test in enumerate(tests):\n    headers = test.get(\"headers\", {})\n    json_data = test.get(\"json\", {})\n    \n    resp = requests.post(\n        f\"{base_url}/v1/analyze\",\n        json={\"symbol\": \"AAPL\", **json_data},\n        headers=headers\n    )\n    print(f\"Test {i+1}: {headers or json_data}\")\n    print(f\"  Status: {resp.status_code}, Response: {resp.text[:80]}\\n\")\n","path":"C:\\Users\\Administrator\\.openclaw\\workspace-finance\\test_api13.py"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.5","usage":{"input":37186,"output":529,"cacheRead":32187,"cacheWrite":0,"totalTokens":69902,"cost":{"input":0.011155799999999999,"output":0.0006347999999999999,"cacheRead":0.0009656099999999999,"cacheWrite":0,"total":0.012756209999999999}},"stopReason":"toolUse","timestamp":1774091797490}}
