{"type":"message","id":"ba470f32","parentId":"a8f076ab","timestamp":"2026-03-17T15:48:11.860Z","message":{"role":"toolResult","toolCallId":"read:77","toolName":"read","content":[{"type":"text","text":"import axios, { AxiosInstance } from 'axios';\nimport type { \n  Agent, \n  Session, \n  Task, \n  MemoryEntry, \n  Document, \n  UsageStats, \n  SystemStats,\n  GatewayStatus \n} from '../types';\n\n// OpenClaw Gateway API client\nclass OpenClawAPI {\n  private client: AxiosInstance;\n  private baseURL: string;\n\n  constructor() {\n    // Default to local gateway, can be configured\n    this.baseURL = import.meta.env.VITE_OPENCLAW_API_URL || 'http://localhost:8080/api';\n    \n    this.client = axios.create({\n      baseURL: this.baseURL,\n      timeout: 10000,\n      headers: {\n        'Content-Type': 'application/json',\n      },\n    });\n\n    // Add auth token if available\n    this.client.interceptors.request.use((config) => {\n      const token = localStorage.getItem('openclaw_token');\n      if (token) {\n        config.headers.Authorization = `Bearer ${token}`;\n      }\n      return config;\n    });\n  }\n\n  // Gateway Status\n  async getGatewayStatus(): Promise<GatewayStatus> {\n    try {\n      // Try to get real status from gateway\n      const response = await this.client.get('/status');\n      return response.data;\n    } catch (error) {\n      // Fallback: try to detect if gateway is running\n      return this.getFallbackGatewayStatus();\n    }\n  }\n\n[255 more lines in file. Use offset=51 to continue.]"}],"isError":false,"timestamp":1773762491855}}
{"type":"message","id":"de662f6d","parentId":"ba470f32","timestamp":"2026-03-17T15:48:23.788Z","message":{"role":"assistant","content":[{"type":"text","text":"让我优化 API 客户端，添加更快的超时和更好的离线模式："},{"type":"toolCall","id":"edit:78","name":"edit","arguments":{"file_path":"C:/Users/Administrator/.openclaw/workspace/control-center/src/api/openclaw.ts","old_string":"  constructor() {\n    // Default to local gateway, can be configured\n    this.baseURL = import.meta.env.VITE_OPENCLAW_API_URL || 'http://localhost:8080/api';\n    \n    this.client = axios.create({\n      baseURL: this.baseURL,\n      timeout: 10000,\n      headers: {\n        'Content-Type': 'application/json',\n      },\n    });","new_string":"  private isOnline: boolean = false;\n  private useMockData: boolean = true;\n\n  constructor() {\n    // Default to local gateway, can be configured\n    this.baseURL = import.meta.env.VITE_OPENCLAW_API_URL || 'http://localhost:8080/api';\n    \n    // Check if we should use real API or mock data\n    this.useMockData = import.meta.env.VITE_USE_MOCK_DATA === 'true' || !this.baseURL;\n    \n    this.client = axios.create({\n      baseURL: this.baseURL,\n      timeout: 2000, // Short timeout for faster fallback\n      headers: {\n        'Content-Type': 'application/json',\n      },\n    });"}}],"api":"openai-completions","provider":"moonshot","model":"kimi-k2.5","usage":{"input":576,"output":311,"cacheRead":89856,"cacheWrite":0,"totalTokens":90743,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773762491862}}
