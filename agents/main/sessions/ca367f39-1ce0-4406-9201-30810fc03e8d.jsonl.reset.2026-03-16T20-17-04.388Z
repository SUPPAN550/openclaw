es[22m[K[36m\r\n- [mResolving desktop-control-win[K\r\n[K\r\n[K\r\n[K\r\n[K\r\n[K\r\n[K\r\n[K\r\n[K\r\n[K\r\n[K\r\n[K\r\n[K\r\n[K\r\n[K\r\n[K\r\n[K\r\n[K\r\n[K\r\n[K\r\n[K\r\n[K[120C[?2026h[?2026l[36m[9;1H\\ [mDownloading desktop-control-win@1.0.1[K[81C[?2026h[?2026l[36m\r| [mDownloading desktop-control-win@1.0.1[K[81C[?2026h[?2026l[36m\r/ [mDownloading desktop-control-win@1.0.1[K[81C[?2026h[?2026l[36m\r- [mDownloading desktop-control-win@1.0.1[K[81C[?2026h[?2026l[36m\r\\ [mDownloading desktop-control-win@1.0.1[K[81C[?2026h[?2026l[36m\r| [mDownloading desktop-control-win@1.0.1[K[81C[?2026h[?2026l[36m\r/ [mDownloading desktop-control-win@1.0.1[K[81C[32m\r√ [mOK. Installed desktop-control-win -> C:\\Users\\Administrator\\.openclaw\\workspace\\skills\\desktop-control-win[K\r\n[?25h","name":"clawhub install"},"isError":false,"timestamp":1773678334666}}
