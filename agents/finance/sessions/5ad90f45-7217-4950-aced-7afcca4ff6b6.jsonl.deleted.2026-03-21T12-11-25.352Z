\n                    print(f\"{key}: {full_result[key]}\")\n            \n            # Check for reports\n            for report_key in ['market_report', 'final_trade_decision', 'decision']:\n                if report_key in full_result:\n                    print(f\"\\n{report_key}: {str(full_result[report_key])[:500]}\")\n            break\n        elif status == \"failed\":\n            print(f\"Error: {status_result.get('error')}\")\n            break\n","path":"C:\\Users\\Administrator\\.openclaw\\workspace-finance\\test_full_analysis2.py"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.5","usage":{"input":64784,"output":603,"cacheRead":32448,"cacheWrite":0,"totalTokens":97835,"cost":{"input":0.0194352,"output":0.0007235999999999999,"cacheRead":0.0009734399999999999,"cacheWrite":0,"total":0.02113224}},"stopReason":"toolUse","timestamp":1774094162876}}
