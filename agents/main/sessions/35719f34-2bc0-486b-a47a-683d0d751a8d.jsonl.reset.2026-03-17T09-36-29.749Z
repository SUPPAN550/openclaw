{"type":"message","id":"1b9590de","parentId":"06bcc9d7","timestamp":"2026-03-17T03:35:25.031Z","message":{"role":"assistant","content":[{"type":"text","text":"子代理超时了，让我直接检查并完善这些文件："},{"type":"toolCall","id":"read:43","name":"read","arguments":{"file_path":"C:\\Users\\Administrator\\.openclaw\\workspace\\openclaw-hub\\server.py"}}],"api":"openai-completions","provider":"moonshot","model":"kimi-k2.5","usage":{"input":7178,"output":48,"cacheRead":38656,"cacheWrite":0,"totalTokens":45882,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773718520763}}
{"type":"message","id":"84d7240d","parentId":"1b9590de","timestamp":"2026-03-17T03:35:25.049Z","message":{"role":"toolResult","toolCallId":"read:43","toolName":"read","content":[{"type":"text","text":"\"\"\"\nOpenClaw Hub Backend Server\n提供真实系统数据和 OpenClaw Agent 状态的 API 服务\n\"\"\"\n\nfrom flask import Flask, jsonify, request\nfrom flask_cors import CORS\nimport psutil\nimport os\nimport subprocess\nimport json\nimport platform\nfrom datetime import datetime\nfrom pathlib import Path\n\napp = Flask(__name__)\nCORS(app)  # 允许跨域请求\n\n# OpenClaw 配置路径\nOPENCLAW_DIR = Path.home() / \".openclaw\"\nAGENTS_DIR = OPENCLAW_DIR / \"agents\"\n\n\ndef run_command(cmd, shell=True):\n    \"\"\"执行系统命令并返回输出\"\"\"\n    try:\n        result = subprocess.run(\n            cmd,\n            shell=shell,\n            capture_output=True,\n            text=True,\n            encoding='utf-8',\n            errors='ignore',\n            timeout=30\n        )\n        return result.stdout.strip(), result.stderr.strip(), result.returncode\n    except Exception as e:\n        return \"\", str(e), -1\n\n\n@app.route('/api/system/stats', methods=['GET'])\ndef get_system_stats():\n    \"\"\"获取系统状态（CPU、内存、存储）\"\"\"\n    try:\n        # CPU 使用率\n        cpu_percent = psutil.cpu_percent(interval=1)\n        cpu_count = psutil.cpu_count()\n        cpu_freq = psutil.cpu_freq()\n        \n        # 内存使用率\n        memory = psutil.virtual_memory()\n        \n        # 磁盘使用率（获取系统盘）\n        if platform.system() == \"Windows\":\n            disk = psutil.disk_usage(\"C:\\\\\")\n        else:\n            disk = psutil.disk_usage(\"/\")\n        \n        # 系统运行时间\n        boot_time = psutil.boot_time()\n        uptime = datetime.now().timestamp() - boot_time\n        \n        return jsonify({\n            \"success\": True,\n            \"data\": {\n                \"cpu\": {\n                    \"usage\": round(cpu_percent, 1),\n                    \"cores\": cpu_count,\n                    \"frequency\": round(cpu_freq.current, 0) if cpu_freq else None\n                },\n                \"memory\": {\n                    \"usage\": round(memory.percent, 1),\n                    \"total\": round(memory.total / (1024**3), 2),  # GB\n                    \"available\": round(memory.available / (1024**3), 2),  # GB\n                    \"used\": round(memory.used / (1024**3), 2)  # GB\n                },\n                \"storage\": {\n                    \"usage\": round(disk.percent, 1),\n                    \"total\": round(disk.total / (1024**3), 2),  # GB\n                    \"used\": round(disk.used / (1024**3), 2),  # GB\n                    \"free\": round(disk.free / (1024**3), 2)  # GB\n                },\n                \"uptime\": int(uptime),\n                \"platform\": platform.system(),\n                \"hostname\": platform.node()\n            }\n        })\n    except Exception as e:\n        return jsonify({\n            \"success\": False,\n            \"error\": str(e)\n        }), 500\n\n\n@app.route('/api/agents', methods=['GET'])\ndef get_agents():\n    \"\"\"获取所有 Agent 列表和状态\"\"\"\n    agents = []\n    \n    try:\n        # 首先尝试从 openclaw status 获取\n        stdout, stderr, returncode = run_command(\"openclaw status --json 2>&1 || openclaw status 2>&1\")\n        \n        # 尝试解析 JSON 输出\n        if returncode == 0:\n            try:\n                status_data = json.loads(stdout)\n                if isinstance(status_data, dict) and \"agents\" in status_data:\n                    return jsonify({\n                        \"success\": True,\n                        \"data\": status_data[\"agents\"],\n                        \"source\": \"openclaw_status\"\n                    })\n            except json.JSONDecodeError:\n                pass\n        \n        # 从 agents 目录读取配置\n        if AGENTS_DIR.exists():\n            for agent_dir in AGENTS_DIR.iterdir():\n                if agent_dir.is_dir():\n                    agent_config_file = agent_dir / \"config.json\"\n                    agent_info = {\n                        \"id\": agent_dir.name,\n                        \"name\": agent_dir.name,\n                        \"displayName\": agent_dir.name.capitalize(),\n                        \"status\": \"offline\",\n                        \"model\": \"unknown\",\n                        \"sessions\": 0,\n                        \"lastActive\": None\n                    }\n                    \n                    # 读取 agent 配置\n                    if agent_config_file.exists():\n                        try:\n                            with open(agent_config_file, 'r', encoding='utf-8') as f:\n                                config = json.load(f)\n                                agent_info[\"displayName\"] = config.get(\"name\", agent_dir.name.capitalize())\n                                agent_info[\"model\"] = config.get(\"model\", \"unknown\")\n                                agent_info[\"description\"] = config.get(\"description\", \"\")\n                        except Exception:\n                            pass\n                    \n                    # 检查 agent 是否在线（通过检查进程或状态文件）\n                    pid_file = agent_dir / \"agent.pid\"\n                    if pid_file.exists():\n                        try:\n                            with open(pid_file, 'r') as f:\n                                pid = int(f.read().strip())\n                                if psutil.pid_exists(pid):\n                                    agent_info[\"status\"] = \"online\"\n                                    proc = psutil.Process(pid)\n                                    agent_info[\"lastActive\"] = datetime.fromtimestamp(\n                                        proc.create_time()\n                                    ).isoformat()\n                        except Exception:\n                            pass\n                    \n                    # 检查会话文件\n                    sessions_dir = agent_dir / \"sessions\"\n                    if sessions_dir.exists():\n                        agent_info[\"sessions\"] = len(list(sessions_dir.iterdir()))\n                    \n                    agents.append(agent_info)\n        \n        # 如果没有找到任何 agent，返回默认配置\n        if not agents:\n            agents = get_default_agents()\n        \n        return jsonify({\n            \"success\": True,\n            \"data\": agents,\n            \"source\": \"filesystem\"\n        })\n        \n    except Exception as e:\n        return jsonify({\n            \"success\": False,\n            \"error\": str(e),\n            \"data\": get_default_agents()\n        })\n\n\ndef get_default_agents():\n    \"\"\"获取默认 Agent 配置\"\"\"\n    return [\n        {\"id\": \"main\", \"name\": \"main\", \"displayName\": \"Main\", \"role\": \"主代理\", \n         \"description\": \"核心主代理，负责协调和管理其他 Agent 的工作流程\", \n         \"icon\": \"fa-robot\", \"color\": \"#6366f1\", \"status\": \"online\", \"model\": \"moonshot/kimi-k2.5\"},\n        {\"id\": \"coder\", \"name\": \"coder\", \"displayName\": \"Coder\", \"role\": \"编程助手\",\n         \"description\": \"专业编程助手，协助代码编写、调试和代码审查\",\n         \"icon\": \"fa-code\", \"color\": \"#06b6d4\", \"status\": \"offline\", \"model\": \"unknown\"},\n        {\"id\": \"researcher\", \"name\": \"researcher\", \"displayName\": \"Researcher\", \"role\": \"研究助手\",\n         \"description\": \"研究助手，负责信息收集、分析和研究报告生成\",\n         \"icon\": \"fa-search\", \"color\": \"#8b5cf6\", \"status\": \"offline\", \"model\": \"unknown\"},\n        {\"id\": \"sysadmin\", \"name\": \"sysadmin\", \"displayName\": \"SysAdmin\", \"role\": \"系统管理\",\n         \"description\": \"系统管理专家，负责服务器维护和系统配置\",\n         \"icon\": \"fa-server\", \"color\": \"#f59e0b\", \"status\": \"offline\", \"model\": \"unknown\"},\n    ]\n\n\n@app.route('/api/agents/<agent_id>/status', methods=['GET'])\ndef get_agent_status(agent_id):\n    \"\"\"获取特定 Agent 的状态\"\"\"\n    try:\n        agent_dir = AGENTS_DIR / agent_id\n        if not agent_dir.exists():\n            return jsonify({\n                \"success\": False,\n                \"error\": f\"Agent {agent_id} not found\"\n            }), 404\n        \n        status = {\n            \"id\": agent_id,\n            \"status\": \"offline\",\n            \"pid\": None,\n            \"lastActive\": None,\n            \"sessions\": 0\n        }\n        \n        # 检查 PID 文件\n        pid_file = agent_dir / \"agent.pid\"\n        if pid_file.exists():\n            try:\n                with open(pid_file, 'r') as f:\n                    pid = int(f.read().strip())\n                    if psutil.pid_exists(pid):\n                        status[\"status\"] = \"online\"\n                        status[\"pid\"] = pid\n                        proc = psutil.Process(pid)\n                        status[\"lastActive\"] = datetime.fromtimestamp(\n                            proc.create_time()\n                        ).isoformat()\n            except Exception:\n                pass\n        \n        # 统计会话数\n        sessions_dir = agent_dir / \"sessions\"\n        if sessions_dir.exists():\n            status[\"sessions\"] = len([s for s in sessions_dir.iterdir() if s.is_dir()])\n        \n        return jsonify({\n            \"success\": True,\n            \"data\": status\n        })\n        \n    except Exception as e:\n        return jsonify({\n            \"success\": False,\n            \"error\": str(e)\n        }), 500\n\n\n@app.route('/api/agents/<agent_id>/<action>', methods=['POST'])\ndef control_agent(agent_id, action):\n    \"\"\"控制 Agent（启动/停止/重启）\"\"\"\n    valid_actions = ['start', 'stop', 'restart']\n    \n    if action not in valid_actions:\n        return jsonify({\n            \"success\": False,\n            \"error\": f\"Invalid action. Valid actions: {', '.join(valid_actions)}\"\n        }), 400\n    \n    try:\n        # 构建命令\n        if action == \"restart\":\n            cmd = f\"openclaw agent restart {agent_id}\"\n        elif action == \"stop\":\n            cmd = f\"openclaw agent stop {agent_id}\"\n        else:  # start\n            cmd = f\"openclaw agent start {agent_id}\"\n        \n        stdout, stderr, returncode = run_command(cmd)\n        \n        if returncode == 0:\n            return jsonify({\n                \"success\": True,\n                \"message\": f\"Agent {agent_id} {action} command executed successfully\",\n                \"output\": stdout\n            })\n        else:\n            return jsonify({\n                \"success\": False,\n                \"error\": stderr or stdout,\n                \"returncode\": returncode\n            }), 500\n            \n    except Exception as e:\n        return jsonify({\n            \"success\": False,\n            \"error\": str(e)\n        }), 500\n\n\n@app.route('/api/openclaw/status', methods=['GET'])\ndef get_openclaw_status():\n    \"\"\"获取 OpenClaw 整体状态\"\"\"\n    try:\n        stdout, stderr, returncode = run_command(\"openclaw status\")\n        \n        return jsonify({\n            \"success\": returncode == 0,\n            \"running\": returncode == 0,\n            \"output\": stdout,\n            \"error\": stderr if stderr else None\n        })\n    except Exception as e:\n        return jsonify({\n            \"success\": False,\n            \"running\": False,\n            \"error\": str(e)\n        })\n\n\n@app.route('/api/control/<action>', methods=['POST'])\ndef system_control(action):\n    \"\"\"系统控制操作\"\"\"\n    valid_actions = {\n        'restart': 'openclaw gateway restart',\n        'stop': 'openclaw gateway stop',\n        'update': 'openclaw update check',\n        'doctor': 'openclaw doctor',\n        'webui': None  # 特殊处理\n    }\n    \n    if action not in valid_actions:\n        return jsonify({\n            \"success\": False,\n            \"error\": f\"Invalid action. Valid actions: {', '.join(valid_actions.keys())}\"\n        }), 400\n    \n    try:\n        if action == 'webui':\n            # WebUI 只是返回 URL，实际打开由前端处理\n            return jsonify({\n                \"success\": True,\n                \"message\": \"WebUI URL\",\n                \"url\": \"http://127.0.0.1:18789/\"\n            })\n        \n        cmd = valid_actions[action]\n        stdout, stderr, returncode = run_command(cmd)\n        \n        if returncode == 0:\n            return jsonify({\n                \"success\": True,\n                \"message\": f\"Command '{action}' executed successfully\",\n                \"output\": stdout\n            })\n        else:\n            return jsonify({\n                \"success\": False,\n                \"error\": stderr or stdout,\n                \"returncode\": returncode\n            }), 500\n            \n    except Exception as e:\n        return jsonify({\n            \"success\": False,\n            \"error\": str(e)\n        }), 500\n\n\n@app.route('/api/sandbox', methods=['GET', 'POST'])\ndef sandbox_mode():\n    \"\"\"获取或切换沙箱模式状态\"\"\"\n    config_file = OPENCLAW_DIR / \"config.json\"\n    \n    if request.method == 'GET':\n        try:\n            if config_file.exists():\n                with open(config_file, 'r', encoding='utf-8') as f:\n                    config = json.load(f)\n                    return jsonify({\n                        \"success\": True,\n                        \"enabled\": config.get(\"sandbox\", {}).get(\"enabled\", False)\n                    })\n            return jsonify({\n                \"success\": True,\n                \"enabled\": False\n            })\n        except Exception as e:\n            return jsonify({\n                \"success\": False,\n                \"error\": str(e)\n            }), 500\n    \n    else:  # POST\n        try:\n            data = request.get_json() or {}\n            enabled = data.get('enabled', True)\n            \n            config = {}\n            if config_file.exists():\n                with open(config_file, 'r', encoding='utf-8') as f:\n                    config = json.load(f)\n            \n            if \"sandbox\" not in config:\n                config[\"sandbox\"] = {}\n            config[\"sandbox\"][\"enabled\"] = enabled\n            \n            with open(config_file, 'w', encoding='utf-8') as f:\n                json.dump(config, f, indent=2)\n            \n            return jsonify({\n                \"success\": True,\n                \"message\": f\"Sandbox mode {'enabled' if enabled else 'disabled'}\",\n                \"enabled\": enabled\n            })\n            \n        except Exception as e:\n            return jsonify({\n                \"success\": False,\n                \"error\": str(e)\n            }), 500\n\n\n@app.route('/api/health', methods=['GET'])\ndef health_check():\n    \"\"\"健康检查端点\"\"\"\n    return jsonify({\n        \"status\": \"ok\",\n        \"timestamp\": datetime.now().isoformat(),\n        \"version\": \"1.0.0\"\n    })\n\n\nif __name__ == '__main__':\n    print(\"=\" * 60)\n    print(\"OpenClaw Hub Backend Server\")\n    print(\"=\" * 60)\n    print(f\"API Endpoint: http://127.0.0.1:5000\")\n    print(f\"System Stats: http://127.0.0.1:5000/api/system/stats\")\n    print(f\"Agents:       http://127.0.0.1:5000/api/agents\")\n    print(f\"Health:       http://127.0.0.1:5000/api/health\")\n    print(\"=\" * 60)\n    print(\"Press Ctrl+C to stop the server\")\n    print(\"=\" * 60)\n    \n    app.run(host='127.0.0.1', port=5000, debug=False)\n"}],"isError":false,"timestamp":1773718525046}}
