ds 5\n    }\n    \n    Start-Sleep -Seconds $CheckInterval\n}\n","file_path":"C:\\Users\\Administrator\\.openclaw\\scripts\\gateway-watchdog.ps1"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":104564,"output":468,"cacheRead":36506,"cacheWrite":0,"totalTokens":141538,"cost":{"input":0.041825600000000004,"output":0.000702,"cacheRead":0.00146024,"cacheWrite":0,"total":0.04398784000000001}},"stopReason":"toolUse","timestamp":1773918223583}}
