{"type":"message","id":"f8a622b2","parentId":"f82b31ea","timestamp":"2026-03-17T03:39:48.686Z","message":{"role":"toolResult","toolCallId":"read:73","toolName":"read","content":[{"type":"text","text":"/**\n * OpenClaw Hub - Agent Matrix 主应用脚本\n * 功能：系统状态监控、Agent 管理、快速控制\n * 修改：连接真实后端 API 获取数据\n */\n\n// ===== API 配置 =====\nconst API_BASE_URL = 'http://127.0.0.1:5000/api';\n\n// ===== Agent 默认配置（用于补充信息）=====\nconst AGENTS_CONFIG = [\n    {\n        id: 'main',\n        name: 'main',\n        displayName: 'Main',\n        role: '主代理',\n        description: '核心主代理，负责协调和管理其他 Agent 的工作流程',\n        icon: 'fa-robot',\n        color: '#6366f1'\n    },\n    {\n        id: 'coder',\n        name: 'coder',\n        displayName: 'Coder',\n        role: '编程助手',\n        description: '专业编程助手，协助代码编写、调试和代码审查',\n        icon: 'fa-code',\n        color: '#06b6d4'\n    },\n    {\n        id: 'researcher',\n        name: 'researcher',\n        displayName: 'Researcher',\n        role: '研究助手',\n        description: '研究助手，负责信息收集、分析和研究报告生成',\n        icon: 'fa-search',\n        color: '#8b5cf6'\n    },\n    {\n        id: 'evolution',\n        name: 'evolution',\n        displayName: 'Evolution',\n        role: '进化/学习',\n        description: '进化学习 Agent，持续优化和自我改进',\n        icon: 'fa-dna',\n        color: '#10b981'\n    },\n    {\n        id: 'sysadmin',\n        name: 'sysadmin',\n\n[576 more lines in file. Use offset=51 to continue.]"}],"isError":false,"timestamp":1773718788683}}
