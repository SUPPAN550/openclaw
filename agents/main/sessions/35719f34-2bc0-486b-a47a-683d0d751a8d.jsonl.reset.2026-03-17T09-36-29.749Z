{"type":"message","id":"866298f1","parentId":"1a7c719a","timestamp":"2026-03-17T05:13:18.582Z","message":{"role":"toolResult","toolCallId":"read:205","toolName":"read","content":[{"type":"text","text":"            \"error\": stderr if stderr else None\n        })\n    except Exception as e:\n        return jsonify({\n            \"success\": False,\n            \"running\": False,\n            \"error\": str(e)\n        })\n\n\n@app.route('/api/control/<action>', methods=['POST'])\ndef system_control(action):\n    \"\"\"系统控制操作\"\"\"\n    valid_actions = {\n        'restart': 'openclaw gateway restart',\n        'stop': 'openclaw gateway stop',\n        'update': 'openclaw update status',\n        'doctor': 'openclaw doctor',\n        'webui': None  # 特殊处理\n    }\n    \n    if action not in valid_actions:\n        return jsonify({\n            \"success\": False,\n            \"error\": f\"Invalid action. Valid actions: {', '.join(valid_actions.keys())}\"\n        }), 400\n    \n    try:\n        if action == 'webui':\n            # WebUI 只是返回 URL，实际打开由前端处理\n            return jsonify({\n                \"success\": True,\n                \"message\": \"WebUI URL\",\n                \"url\": \"http://127.0.0.1:18789/\"\n            })\n        \n        cmd = valid_actions[action]\n        stdout, stderr, returncode = run_command(cmd)\n        \n        if returncode == 0:\n            return jsonify({\n                \"success\": True,\n                \"message\": f\"Command '{action}' executed successfully\",\n                \"output\": stdout\n            })\n        else:\n            return jsonify({\n                \"success\": False,\n                \"error\": stderr or stdout,\n                \"returncode\": returncode\n            }), 500\n            \n    except Exception as e:\n        return jsonify({\n            \"success\": False,\n            \"error\": str(e)\n        }), 500\n\n\n@app.route('/api/sandbox', methods=['GET', 'POST'])\n\n[77 more