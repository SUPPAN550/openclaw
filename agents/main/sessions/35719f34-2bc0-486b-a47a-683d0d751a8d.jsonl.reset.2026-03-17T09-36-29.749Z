{"type":"message","id":"2c234228","parentId":"0ed33a70","timestamp":"2026-03-17T03:39:51.218Z","message":{"role":"toolResult","toolCallId":"read:74","toolName":"read","content":[{"type":"text","text":"        'restart': '重启'\n    };\n    return actionMap[action] || action;\n}\n\n// ===== 系统监控 =====\nfunction startSystemMonitoring() {\n    updateSystemStats();\n    systemStatsInterval = setInterval(updateSystemStats, 3000);\n}\n\n// ===== Agent 监控 =====\nfunction startAgentsMonitoring() {\n    agentsRefreshInterval = setInterval(loadAgents, 10000); // 每10秒刷新一次\n}\n\n// ===== 更新系统状态 =====\nasync function updateSystemStats() {\n    try {\n        const response = await fetch(`${API_BASE_URL}/system/stats`);\n        const result = await response.json();\n        \n        if (result.success && result.data) {\n            const data = result.data;\n            \n            // 更新 CPU\n            if (data.cpu) {\n                document.getElementById('cpu-usage').textContent = `${data.cpu.usage}%`;\n                document.getElementById('cpu-bar').style.width = `${Math.min(data.cpu.usage, 100)}%`;\n            }\n            \n            // 更新内存\n            if (data.memory) {\n                document.getElementById('memory-usage').textContent = `${data.memory.usage}%`;\n                document.getElementById('memory-bar').style.width = `${Math.min(data.memory.usage, 100)}%`;\n            }\n            \n            // 更新存储\n            if (data.storage) {\n                document.getElementById('storage-usage').textContent = `${data.storage.usage}%`;\n                document.getElementById('storage-bar').style.width = `${Math.min(data.storage.usage, 100)}%`;\n            }\n        }\n    } catch (error) {\n        console.error('更新系统状态失败:', error);\n        // 显示离线状态\n        document.getElementById('cpu-usage').textContent = '--';\n        document.getElementById('memory-usage').textContent = '--';\n        document.getElementById('storage-usage').textContent = '--';\n    }\n}\n\n// ===== 绑定事件 =====\nfunction bindEvents() {\n    // 模态框关闭\n    const closeModalBtn = document.getElementById('close-modal');\n    if (closeModalBtn) {\n        closeModalBtn.addEventListener('click', closeAgentModal);\n    }\n    \n    const modal = document.getElementById('agent-modal');\n    if (modal) {\n        modal.addEventListener('click', (e) => {\n            if (e.target === modal) {\n                closeAgentModal();\n            }\n        });\n    }\n    \n    // 模态框操作按钮\n    const modalStart = document.getElementById('modal-start');\n    const modalStop = document.getElementById('modal-stop');\n    const modalRestart = document.getElementById('modal-restart');\n    const modalChat = document.getElementById('modal-chat');\n    \n    if (modalStart) {\n        modalStart.addEventListener('click', () => {\n            if (currentAgent) handleAgentAction(currentAgent.id, 'start');\n        });\n    }\n    \n    if (modalStop) {\n        modalStop.addEventListener('click', () => {\n            if (currentAgent) handleAgentAction(currentAgent.id, 'stop');\n        });\n    }\n    \n    if (modalRestart) {\n        modalRestart.addEventListener('click', () => {\n            if (currentAgent) handleAgentAction(currentAgent.id, 'restart');\n        });\n    }\n    \n    if (modalChat) {\n        modalChat.addEventListener('click', () => {\n            if (currentAgent) enterChat(currentAgent.id);\n        });\n    }\n    \n    // 快速控制按钮\n\n[127 more lines in file. Use offset=500 to continue.]"}],"isError":false,"timestamp":1773718791210}}
{"type":"message","id":"c487ff8b","parentId":"2c234228","timestamp":"2026-03-17T03:39:53.561Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"read:75","name":"read","arguments":{"file_path":"D:\\openclaw-hub\\app.js","offset":500,"limit":100}}],"api":"openai-completions","provider":"moonshot","model":"kimi-k2.5","usage":{"input":935,"output":33,"cacheRead":66304,"cacheWrite":0,"totalTokens":67272,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773718791219}}
{"type":"message","id":"5ed48f80","parentId":"c487ff8b","timestamp":"2026-03-17T03:39:53.582Z","message":{"role":"toolResult","toolCallId":"read:75","toolName":"read","content":[{"type":"text","text":"    bindControlButton('btn-webui', 'webui', '正在打开 WebUI...', () => {\n        window.open('http://127.0.0.1:18789/', '_blank');\n    });\n    \n    bindControlButton('btn-restart', 'restart', '正在重启 OpenClaw 服务...', null, true);\n    bindControlButton('btn-update', 'update', '正在检查更新...');\n    bindControlButton('btn-repair', 'doctor', '正在运行故障修复...');\n    bindControlButton('btn-sandbox', 'sandbox', '正在切换沙箱模式...', toggleSandboxMode);\n    bindControlButton('btn-stop', 'stop', '正在停止 OpenClaw 服务...', null, true);\n    \n    // 键盘快捷键\n    document.addEventListener('keydown', (e) => {\n        if (e.key === 'Escape') {\n            closeAgentModal();\n        }\n    });\n}\n\n// ===== 绑定控制按钮 =====\nfunction bindControlButton(btnId, action, loadingMessage, customHandler = null, needConfirm = false) {\n    const btn = document.getElementById(btnId);\n    if (!btn) return;\n    \n    btn.addEventListener('click', async () => {\n        if (needConfirm) {\n            const confirmMsg = action === 'stop' \n                ? '确定要停止 OpenClaw 服务吗？' \n                : '确定要重启 OpenClaw 服务吗？';\n            if (!confirm(confirmMsg)) return;\n        }\n        \n        showNotification(loadingMessage);\n        \n        if (customHandler) {\n            await customHandler();\n            return;\n        }\n        \n        try {\n            const response = await fetch(`${API_BASE_URL}/control/${action}`, {\n                method: 'POST',\n                headers: { 'Content-Type': 'application/json' }\n            });\n            \n            const result = await response.json();\n            \n            if (result.success) {\n                showNotification(result.message || '操作完成');\n                \n                // 特殊处理 WebUI\n                if (action === 'webui' && result.url) {\n                    window.open(result.url, '_blank');\n                }\n            } else {\n                showNotification(`操作失败: ${result.error || '未知错误'}`, 5000);\n            }\n        } catch (error) {\n            console.error('控制操作失败:', error);\n            showNotification(`操作失败: ${error.message}`, 5000);\n        }\n    });\n}\n\n// ===== 切换沙箱模式 =====\nasync function toggleSandboxMode() {\n    try {\n        // 先获取当前状态\n        const response = await fetch(`${API_BASE_URL}/sandbox`);\n        const result = await response.json();\n        \n        const currentEnabled = result.success ? result.enabled : false;\n        const newEnabled = !currentEnabled;\n        \n        // 切换状态\n        const toggleResponse = await fetch(`${API_BASE_URL}/sandbox`, {\n            method: 'POST',\n            headers: { 'Content-Type': 'application/json' },\n            body: JSON.stringify({ enabled: newEnabled })\n        });\n        \n        const toggleResult = await toggleResponse.json();\n        \n        if (toggleResult.success) {\n            showNotification(`沙箱模式已${newEnabled ? '启用' : '禁用'}`);\n        } else {\n            showNotification(`切换沙箱模式失败: ${toggleResult.error || '未知错误'}`, 5000);\n        }\n    } catch (error) {\n        console.error('切换沙箱模式失败:', error);\n        showNotification(`切换沙箱模式失败: ${error.message}`, 5000);\n    }\n}\n\n// ===== 进入对话 =====\nfunction enterChat(agentId) {\n    const agent = agentsData.find(a => a.id === agentId);\n    if (!agent) return;\n    \n    showNotification(`正在进入 ${agent.displayName} 对话...`);\n    window.open(`http://127.0.0.1:18789/chat/${agentId}`, '_blank');\n\n[27 more lines in file. Use offset=600 to continue.]"}],"isError":false,"timestamp":1773718793565}}
{"type":"message","id":"f07e14cc","parentId":"5ed48f80","timestamp":"2026-03-17T03:39:56.268Z","message":{"role":"assistant","content":[{"type":"text","text":"前端代码看起来正确。现在让我检查 index.html 确保所有按钮都有正确的 ID："},{"type":"toolCall","id":"read:76","name":"read","arguments":{"file_path":"D:\\openclaw-hub\\index.html"}}],"api":"openai-completions","provider":"moonshot","model":"kimi-k2.5","usage":{"input":1051,"output":43,"cacheRead":67072,"cacheWrite":0,"totalTokens":68166,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773718793583}}
{"type":"message","id":"8b2ee7a4","parentId":"f07e14cc","timestamp":"2026-03-17T03:39:56.283Z","message":{"role":"toolResult","toolCallId":"read:76","toolName":"read","content":[{"type":"text","text":"<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>OpenClaw Hub - Agent Matrix</title>\n    <link rel=\"stylesheet\" href=\"style.css\">\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\">\n</head>\n<body>\n    <div class=\"container\">\n        <!-- 顶部系统状态监控 -->\n        <header class=\"header\">\n            <div class=\"logo\">\n                <i class=\"fas fa-claw\"></i>\n                <h1>OpenClaw Hub</h1>\n            </div>\n            <div class=\"system-status\">\n                <div class=\"status-item\">\n                    <div class=\"status-icon cpu\">\n                        <i class=\"fas fa-microchip\"></i>\n                    </div>\n                    <div class=\"status-info\">\n                        <span class=\"status-label\">CPU</span>\n                        <span class=\"status-value\" id=\"cpu-usage\">0%</span>\n                    </div>\n                    <div class=\"progress-bar\">\n                        <div class=\"progress-fill\" id=\"cpu-bar\"></div>\n                    </div>\n                </div>\n                <div class=\"status-item\">\n                    <div class=\"status-icon memory\">\n                        <i class=\"fas fa-memory\"></i>\n                    </div>\n                    <div class=\"status-info\">\n                        <span class=\"status-label\">内存</span>\n                        <span class=\"status-value\" id=\"memory-usage\">0%</span>\n                    </div>\n                    <div class=\"progress-bar\">\n                        <div class=\"progress-fill\" id=\"memory-bar\"></div>\n                    </div>\n                </div>\n                <div class=\"status-item\">\n                    <div class=\"status-icon storage\">\n                        <i class=\"fas fa-hdd\"></i>\n                    </div>\n                    <div class=\"status-info\">\n                        <span class=\"status-label\">存储</span>\n                        <span class=\"status-value\" id=\"storage-usage\">0%</span>\n                    </div>\n                    <div class=\"progress-bar\">\n                        <div class=\"progress-fill\" id=\"storage-bar\"></div>\n                    </div>\n                </div>\n            </div>\n        </header>\n\n        <!-- 中间 Agent Matrix -->\n        <main class=\"main-content\">\n            <div class=\"section-header\">\n                <h2><i class=\"fas fa-th\"></i> Agent Matrix</h2>\n                <div class=\"status-legend\">\n                    <span class=\"legend-item\"><span class=\"dot online\"></span>在线</span>\n                    <span class=\"legend-item\"><span class=\"dot offline\"></span>离线</span>\n                    <span class=\"legend-item\"><span class=\"dot busy\"></span>忙碌</span>\n                </div>\n            </div>\n            <div class=\"agent-grid\" id=\"agent-grid\">\n                <!-- Agent 卡片将通过 JavaScript 动态生成 -->\n            </div>\n        </main>\n\n        <!-- 底部快速控制区 -->\n        <footer class=\"footer\">\n            <div class=\"quick-controls\">\n                <h3><i class=\"fas fa-bolt\"></i> 快速控制</h3>\n                <div class=\"control-buttons\">\n                    <button class=\"control-btn primary\" id=\"btn-webui\">\n                        <i class=\"fas fa-globe\"></i>\n                        <span>进入 WebUI</span>\n                    </button>\n                    <button class=\"control-btn\" id=\"btn-restart\">\n                        <i class=\"fas fa-redo\"></i>\n                        <span>重启服务</span>\n                    </button>\n                    <button class=\"control-btn\" id=\"btn-update\">\n                        <i class=\"fas fa-sync-alt\"></i>\n                        <span>检查更新</span>\n                    </button>\n                    <button class=\"control-btn\" id=\"btn-repair\">\n                        <i class=\"fas fa-wrench\"></i>\n                        <span>故障修复</span>\n                    </button>\n                    <button class=\"control-btn\" id=\"btn-sandbox\">\n                        <i class=\"fas fa-box\"></i>\n                        <span>沙箱模式</span>\n                    </button>\n                    <button class=\"control-btn danger\" id=\"btn-stop\">\n                        <i class=\"fas fa-power-off\"></i>\n                        <span>停止服务</span>\n                    </button>\n                </div>\n            </div>\n        </footer>\n    </div>\n\n    <!-- Agent 详情模态框 -->\n    <div class=\"modal\" id=\"agent-modal\">\n        <div class=\"modal-content\">\n            <div class=\"modal-header\">\n                <h2 id=\"modal-title\">Agent 详情</h2>\n                <button class=\"close-btn\" id=\"close-modal\">\n                    <i class=\"fas fa-times\"></i>\n                </button>\n            </div>\n            <div class=\"modal-body\">\n                <div class=\"agent-info\">\n                    <div class=\"agent-avatar-large\" id=\"modal-avatar\"></div>\n                    <div class=\"agent-details\">\n                        <h3 id=\"modal-agent-name\"></h3>\n                        <p id=\"modal-agent-desc\"></p>\n                        <div class=\"agent-status-large\">\n                            <span class=\"status-badge\" id=\"modal-status\"></span>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"agent-actions\">\n                    <button class=\"action-btn start\" id=\"modal-start\">\n                        <i class=\"fas fa-play\"></i> 启动\n                    </button>\n                    <button class=\"action-btn stop\" id=\"modal-stop\">\n                        <i class=\"fas fa-stop\"></i> 停止\n                    </button>\n                    <button class=\"action-btn restart\" id=\"modal-restart\">\n                        <i class=\"fas fa-redo\"></i> 重启\n                    </button>\n                    <button class=\"action-btn chat\" id=\"modal-chat\">\n                        <i class=\"fas fa-comments\"></i> 进入对话\n                    </button>\n                </div>\n                <div class=\"agent-logs\">\n                    <h4><i class=\"fas fa-terminal\"></i> 运行日志</h4>\n                    <div class=\"log-container\" id=\"log-container\">\n                        <div class=\"log-entry\">等待启动...</div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <!-- 通知提示 -->\n    <div class=\"notification\" id=\"notification\">\n        <i class=\"fas fa-info-circle\"></i>\n        <span id=\"notification-text\"></span>\n    </div>\n\n    <script src=\"app.js\"></script>\n</body>\n</html>\n"}],"isError":false,"timestamp":1773718796279}}
