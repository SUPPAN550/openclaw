{"type":"message","id":"fabe5dd4","parentId":"7bbd5f4a","timestamp":"2026-03-17T15:41:56.199Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"write:62","name":"write","arguments":{"content":"import axios, { AxiosInstance } from 'axios';\nimport type { \n  Agent, \n  Session, \n  Task, \n  MemoryEntry, \n  Document, \n  UsageStats, \n  SystemStats,\n  GatewayStatus \n} from '../types';\n\n// OpenClaw Gateway API client\nclass OpenClawAPI {\n  private client: AxiosInstance;\n  private baseURL: string;\n\n  constructor() {\n    // Default to local gateway, can be configured\n    this.baseURL = import.meta.env.VITE_OPENCLAW_API_URL || 'http://localhost:8080/api';\n    \n    this.client = axios.create({\n      baseURL: this.baseURL,\n      timeout: 10000,\n      headers: {\n        'Content-Type': 'application/json',\n      },\n    });\n\n    // Add auth token if available\n    this.client.interceptors.request.use((config) => {\n      const token = localStorage.getItem('openclaw_token');\n      if (token) {\n        config.headers.Authorization = `Bearer ${token}`;\n      }\n      return config;\n    });\n  }\n\n  // Gateway Status\n  async getGatewayStatus(): Promise<GatewayStatus> {\n    try {\n      // Try to get real status from gateway\n      const response = await this.client.get('/status');\n      return response.data;\n    } catch (error) {\n      // Fallback: try to detect if gateway is running\n      return this.getFallbackGatewayStatus();\n    }\n  }\n\n  private async getFallbackGatewayStatus(): Promise<GatewayStatus> {\n    try {\n      // Simple health check\n      await axios.get('http://localhost:8080/health', { timeout: 3000 });\n      return {\n        status: 'online',\n        version: '2026.3.13',\n        uptime: 'Unknown',\n        connectedNodes: 0\n      };\n    } catch {\n      return {\n        status: 'offline',\n        version: 'Unknown',\n        uptime: '0',\n        connectedNodes: 0\n      };\n    }\n  }\n\n  // Agents\n  async getAgents(): Promise<Agent[]> {\n    try {\n      const response = await this.client.get('/agents');\n      return response.data;\n    } catch (error) {\n      // Fallback: load from navigation.json\n      return this.getFallbackAgents();\n    }\n  }\n\n  private async getFallbackAgents(): Promise<Agent[]> {\n    try {\n      const response = await fetch('/navigation.json');\n      const data = await response.json();\n      return data.agents.map((agent: any) => ({\n        ...agent,\n        status: Math.random() > 0.3 ? 'active' : 'idle',\n        lastActive: new Date().toISOString(),\n        taskCount: Math.floor(Math.random() * 20)\n      }));\n    } catch {\n      return [];\n    }\n  }\n\n  // Sessions\n  async getSessions(): Promise<Session[]> {\n    try {\n      const response = await this.client.get('/sessions');\n      return response.data;\n    } catch {\n      return this.getFallbackSessions();\n    }\n  }\n\n  private getFallbackSessions(): Session[] {\n    return [\n      {\n        sessionKey: 'main',\n        status: 'active',\n        lastActive: new Date().toISOString(),\n        messageCount: 156\n      }\n    ];\n  }\n\n  // Tasks\n  async getTasks(): Promise<Task[]> {\n    try {\n      const response = await this.client.get('/tasks');\n      return response.data;\n    } catch {\n      return this.getFallbackTasks();\n    }\n  }\n\n  private getFallbackTasks(): Task[] {\n    const now = new Date();\n    return [\n      {\n        id: '1',\n        title: '完成控制面板 UI 设计',\n        description: '设计 OpenClaw 控制面板的用户界面',\n        status: 'in_progress',\n        priority: 'high',\n        assignee: 'Jarvis',\n        progress: 78,\n        createdAt: now.toISOString(),\n        updatedAt: now.toISOString(),\n        tags: ['UI设计', '前端']\n      },\n      {\n        id: '2',\n        title: 'API 接口性能优化',\n        description: '优化用户查询接口的响应时间',\n        status: 'pending',\n        priority: 'high',\n        assignee: 'TARS',\n        progress: 0,\n        createdAt: new Date(now.getTime() - 86400000).toISOString(),\n        updatedAt: new Date(now.getTime() - 86400000).toISOString(),\n        tags: ['后端', '性能优化']\n      },\n      {\n        id: '3',\n        title: '数据分析报告生成',\n        description: '生成 Q1 用户行为分析报告',\n        status: 'completed',\n        priority: 'medium',\n        assignee: 'Friday',\n        progress: 100,\n        createdAt: new Date(now.getTime() - 172800000).toISOString(),\n        updatedAt: new Date(now.getTime() - 86400000).toISOString(),\n        tags: ['数据分析', '报告']\n      }\n    ];\n  }\n\n  // Memory\n  async getMemoryEntries(): Promise<MemoryEntry[]> {\n    try {\n      const response = await this.client.get('/memory');\n      return response.data;\n    } catch {\n      return this.getFallbackMemory();\n    }\n  }\n\n  private getFallbackMemory(): MemoryEntry[] {\n    return [\n      {\n        id: '1',\n        content: 'Sir 偏好深色主题界面，专业简洁风格',\n        category: 'preferences',\n        tags: ['UI', '主题', '偏好'],\n        createdAt: new Date().toISOString(),\n        source: 'conversation'\n      },\n      {\n        id: '2',\n        content: 'Control Center 项目创建于 2026-03-17',\n        category: 'events',\n        tags: ['项目', '里程碑'],\n        createdAt: new Date().toISOString(),\n        source: 'system'\n      }\n    ];\n  }\n\n  // Documents\n  async getDocuments(): Promise<Document[]> {\n    try {\n      const response = await this.client.get('/documents');\n      return response.data;\n    } catch {\n      return this.getFallbackDocuments();\n    }\n  }\n\n  private getFallbackDocuments(): Document[] {\n    return [\n      {\n        id: '1',\n        title: 'OpenClaw 配置指南',\n        type: 'doc',\n        status: 'active',\n        lastModified: new Date().toISOString(),\n        modifiedBy: 'Jarvis',\n        size: 25600\n      },\n      {\n        id: '2',\n        title: 'API 接口文档',\n        type: 'doc',\n        status: 'active',\n        lastModified: new Date(Date.now() - 86400000).toISOString(),\n        modifiedBy: 'TARS',\n        size: 51200\n      }\n    ];\n  }\n\n  // Usage Stats\n  async getUsageStats(days: number = 7): Promise<UsageStats[]> {\n    try {\n      const response = await this.client.get(`/usage?days=${days}`);\n      return response.data;\n    } catch {\n      return this.generateFallbackUsageStats(days);\n    }\n  }\n\n  private generateFallbackUsageStats(days: number): UsageStats[] {\n    const stats: UsageStats[] = [];\n    const now = new Date();\n    \n    for (let i = days - 1; i >= 0; i--) {\n      const date = new Date(now);\n      date.setDate(date.getDate() - i);\n      \n      stats.push({\n        date: date.toISOString().split('T')[0],\n        tokens: Math.floor(Math.random() * 50000) + 50000,\n        requests: Math.floor(Math.random() * 500) + 100,\n        cost: Math.random() * 5 + 1\n      });\n    }\n    \n    return stats;\n  }\n\n  // System Stats\n  async getSystemStats(): Promise<SystemStats> {\n    try {\n      const response = await this.client.get('/stats');\n      return response.data;\n    } catch {\n      return this.getFallbackSystemStats();\n    }\n  }\n\n  private async getFallbackSystemStats(): Promise<SystemStats> {\n    const agents = await this.getFallbackAgents();\n    const tasks = this.getFallbackTasks();\n    \n    return {\n      activeAgents: agents.filter(a => a.status === 'active').length,\n      totalTasks: tasks.length,\n      completedTasks: tasks.filter(t => t.status === 'completed').length,\n      pendingTasks: tasks.filter(t => t.status === 'pending').length,\n      uptime: 99.9,\n      totalTokens: 2450000,\n      apiCalls: 15600\n    };\n  }\n\n  // Execute action\n  async executeAction(action: string, params?: any): Promise<any> {\n    try {\n      const response = await this.client.post('/action', { action, params });\n      return response.data;\n    } catch (error) {\n      throw new Error(`Action failed: ${action}`);\n    }\n  }\n}\n\n// Export singleton instance\nexport const openclawAPI = new OpenClawAPI();\n\n// Export class for custom instances\nexport { OpenClawAPI };\n","path":"C:/Users/Administrator/.openclaw/workspace/control-center/src/api/openclaw.ts"}}],"api":"openai-completions","provider":"moonshot","model":"kimi-k2.5","usage":{"input":853,"output":2278,"cacheRead":68352,"cacheWrite":0,"totalTokens":71483,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773762056462}}
{"type":"message","id":"f01d7c68","parentId":"fabe5dd4","timestamp":"2026-03-17T15:41:56.209Z","message":{"role":"toolResult","toolCallId":"write:62","toolName":"write","content":[{"type":"text","text":"Successfully wrote 7613 bytes to C:/Users/Administrator/.openclaw/workspace/control-center/src/api/openclaw.ts"}],"isError":false,"timestamp":1773762116205}}
{"type":"message","id":"27d74c9c","parentId":"f01d7c68","timestamp":"2026-03-17T15:42:20.384Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"write:63","name":"write","arguments":{"content":"import { useState, useEffect, useCallback } from 'react';\nimport { openclawAPI } from '../api/openclaw';\nimport type { Agent, Session, Task, MemoryEntry, Document, UsageStats, SystemStats, GatewayStatus } from '../types';\n\n// Generic hook for API data fetching\nexport function useOpenClawData<T>(\n  fetcher: () => Promise<T>,\n  initialData: T,\n  refreshInterval?: number\n) {\n  const [data, setData] = useState<T>(initialData);\n  const [loading, setLoading] = useState(true);\n  const [error, setError] = useState<Error | null>(null);\n\n  const fetch = useCallback(async () => {\n    try {\n      setLoading(true);\n      const result = await fetcher();\n      setData(result);\n      setError(null);\n    } catch (err) {\n      setError(err instanceof Error ? err : new Error('Unknown error'));\n    } finally {\n      setLoading(false);\n    }\n  }, [fetcher]);\n\n  useEffect(() => {\n    fetch();\n    \n    if (refreshInterval) {\n      const interval = setInterval(fetch, refreshInterval);\n      return () => clearInterval(interval);\n    }\n  }, [fetch, refreshInterval]);\n\n  return { data, loading, error, refetch: fetch };\n}\n\n// Specific hooks\nexport function useAgents(refreshInterval?: number) {\n  return useOpenClawData<Agent[]>(\n    () => openclawAPI.getAgents(),\n    [],\n    refreshInterval\n  );\n}\n\nexport function useSessions(refreshInterval?: number) {\n  return useOpenClawData<Session[]>(\n    () => openclawAPI.getSessions(),\n    [],\n    refreshInterval\n  );\n}\n\nexport function useTasks(refreshInterval?: number) {\n  return useOpenClawData<Task[]>(\n    () => openclawAPI.getTasks(),\n    [],\n    refreshInterval\n  );\n}\n\nexport function useMemory(refreshInterval?: number) {\n  return useOpenClawData<MemoryEntry[]>(\n    () => openclawAPI.getMemoryEntries(),\n    [],\n    refreshInterval\n  );\n}\n\nexport function useDocuments(refreshInterval?: number) {\n  return useOpenClawData<Document[]>(\n    () => openclawAPI.getDocuments(),\n    [],\n    refreshInterval\n  );\n}\n\nexport function useUsageStats(days: number = 7) {\n  return useOpenClawData<UsageStats[]>(\n    () => openclawAPI.getUsageStats(days),\n    [],\n    30000 // Refresh every 30 seconds\n  );\n}\n\nexport function useSystemStats(refreshInterval?: number) {\n  return useOpenClawData<SystemStats>(\n    () => openclawAPI.getSystemStats(),\n    {\n      activeAgents: 0,\n      totalTasks: 0,\n      completedTasks: 0,\n      pendingTasks: 0,\n      uptime: 100,\n      totalTokens: 0,\n      apiCalls: 0\n    },\n    refreshInterval\n  );\n}\n\nexport function useGatewayStatus(refreshInterval: number = 10000) {\n  return useOpenClawData<GatewayStatus>(\n    () => openclawAPI.getGatewayStatus(),\n    {\n      status: 'offline',\n      version: 'Unknown',\n      uptime: '0',\n      connectedNodes: 0\n    },\n    refreshInterval\n  );\n}\n","path":"C:/Users/Administrator/.openclaw/workspace/control-center/src/hooks/useOpenClaw.ts"}}],"api":"openai-completions","provider":"moonshot","model":"kimi-k2.5","usage":{"input":355,"output":888,"cacheRead":71168,"cacheWrite":0,"totalTokens":72411,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773762116210}}
