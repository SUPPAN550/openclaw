n config;\n      });\n    } else {\n      // Create a dummy client that will never be used\n      this.client = axios.create();\n    }\n  }"}}],"api":"openai-completions","provider":"moonshot","model":"kimi-k2.5","usage":{"input":193,"output":538,"cacheRead":142592,"cacheWrite":0,"totalTokens":143323,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773763193941}}
