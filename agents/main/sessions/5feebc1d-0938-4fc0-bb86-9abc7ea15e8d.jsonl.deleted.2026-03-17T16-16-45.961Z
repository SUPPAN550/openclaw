{"type":"message","id":"aa68f8fd","parentId":"f8df03b4","timestamp":"2026-03-17T15:22:12.153Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"write:11","name":"write","arguments":{"content":"import { useState } from 'react'\nimport {\n  Users,\n  Plus,\n  Search,\n  Filter,\n  MoreHorizontal,\n  Play,\n  Pause,\n  Settings,\n  Trash2,\n  Edit,\n  Copy,\n  Bot,\n  MessageSquare,\n  FileText,\n  Code,\n  Sparkles\n} from 'lucide-react'\n\nconst agents = [\n  {\n    id: 1,\n    name: 'Jarvis',\n    role: '通用助手',\n    status: 'active',\n    type: 'general',\n    description: '主要个人助手，负责日常任务处理和协调',\n    lastActive: '2分钟前',\n    tasksCompleted: 1247,\n    successRate: 98.5,\n    model: 'GPT-4',\n    capabilities: ['对话', '文档', '代码', '分析'],\n  },\n  {\n    id: 2,\n    name: 'Friday',\n    role: '数据分析师',\n    status: 'active',\n    type: 'analyst',\n    description: '专注于数据处理和可视化分析',\n    lastActive: '5分钟前',\n    tasksCompleted: 856,\n    successRate: 96.2,\n    model: 'Claude-3',\n    capabilities: ['数据分析', '图表', '报告'],\n  },\n  {\n    id: 3,\n    name: 'Alfred',\n    role: '文档管家',\n    status: 'idle',\n    type: 'document',\n    description: '文档管理、整理和归档专家',\n    lastActive: '1小时前',\n    tasksCompleted: 2341,\n    successRate: 99.1,\n    model: 'GPT-4',\n    capabilities: ['文档', '搜索', '归档'],\n  },\n  {\n    id: 4,\n    name: 'TARS',\n    role: '代码助手',\n    status: 'active',\n    type: 'code',\n    description: '编程辅助、代码审查和技术咨询',\n    lastActive: '刚刚',\n    tasksCompleted: 3422,\n    successRate: 94.8,\n    model: 'GPT-4-Turbo',\n    capabilities: ['代码', '审查', '调试'],\n  },\n  {\n    id: 5,\n    name: 'C-3PO',\n    role: '翻译专员',\n    status: 'idle',\n    type: 'language',\n    description: '多语言翻译和本地化专家',\n    lastActive: '3小时前',\n    tasksCompleted: 567,\n    successRate: 97.3,\n    model: 'Claude-3',\n    capabilities: ['翻译', '本地化', '润色'],\n  },\n  {\n    id: 6,\n    name: 'Data',\n    role: '研究员',\n    status: 'active',\n    type: 'research',\n    description: '深度研究、信息收集和知识整理',\n    lastActive: '15分钟前',\n    tasksCompleted: 423,\n    successRate: 95.6,\n    model: 'GPT-4',\n    capabilities: ['研究', '搜索', '总结'],\n  },\n]\n\nconst typeIcons: Record<string, React.ElementType> = {\n  general: Sparkles,\n  analyst: Bot,\n  document: FileText,\n  code: Code,\n  language: MessageSquare,\n  research: Search,\n}\n\nconst typeColors: Record<string, string> = {\n  general: 'bg-purple-500/10 text-purple-400 border-purple-500/20',\n  analyst: 'bg-blue-500/10 text-blue-400 border-blue-500/20',\n  document: 'bg-green-500/10 text-green-400 border-green-500/20',\n  code: 'bg-orange-500/10 text-orange-400 border-orange-500/20',\n  language: 'bg-pink-500/10 text-pink-400 border-pink-500/20',\n  research: 'bg-cyan-500/10 text-cyan-400 border-cyan-500/20',\n}\n\nexport default function Agents() {\n  const [searchQuery, setSearchQuery] = useState('')\n  const [statusFilter, setStatusFilter] = useState('all')\n  const [selectedAgents, setSelectedAgents] = useState<number[]>([])\n\n  const filteredAgents = agents.filter((agent) => {\n    const matchesSearch = agent.name.toLowerCase().includes(searchQuery.toLowerCase()) ||\n      agent.role.toLowerCase().includes(searchQuery.toLowerCase())\n    const matchesStatus = statusFilter === 'all' || agent.status === statusFilter\n    return matchesSearch && matchesStatus\n  })\n\n  const toggleAgentSelection = (id: number) => {\n    setSelectedAgents((prev) =>\n      prev.includes(id) ? prev.filter((a) => a !== id) : [...prev, id]\n    )\n  }\n\n  return (\n    <div className=\"space-y-6\">\n      {/* Header */}\n      <div className=\"flex items-center justify-between\">\n        <div>\n          <h1 className=\"text-2xl font-bold text-white\">员工 Agents</h1>\n          <p className=\"text-dark-400 mt-1\">管理和配置您的 AI 工作团队</p>\n        </div>\n        <button className=\"flex items-center gap-2 bg-primary-600 hover:bg-primary-700 text-white px-4 py-2 rounded-lg transition-colors\">\n          <Plus className=\"w-4 h-4\" />\n          <span>新建员工</span>\n        </button>\n      </div>\n\n      {/* Stats */}\n      <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-4\">\n        <div className=\"bg-dark-900 border border-dark-800 rounded-xl p-5\">\n          <div className=\"flex items-center gap-3\">\n            <div className=\"p-3 bg-primary-500/10 rounded-xl\">\n              <Users className=\"w-5 h-5 text-primary-400\" />\n            </div>\n            <div>\n              <p className=\"text-dark-400 text-sm\">总员工数</p>\n              <p className=\"text-xl font-bold text-white\">{agents.length}</p>\n            </div>\n          </div>\n        </div>\n        <div className=\"bg-dark-900 border border-dark-800 rounded-xl p-5\">\n          <div className=\"flex items-center gap-3\">\n            <div className=\"p-3 bg-green-500/10 rounded-xl\">\n              <Play className=\"w-5 h-5 text-green-400\" />\n            </div>\n            <div>\n              <p className=\"text-dark-400 text-sm\">运行中</p>\n              <p className=\"text-xl font-bold text-white\">\n                {agents.filter((a) => a.status === 'active').length}\n              </p>\n            </div>\n          </div>\n        </div>\n        <div className=\"bg-dark-900 border border-dark-800 rounded-xl p-5\">\n          <div className=\"flex items-center gap-3\">\n            <div className=\"p-3 bg-blue-500/10 rounded-xl\">\n              <Bot className=\"w-5 h-5 text-blue-400\" />\n            </div>\n            <div>\n              <p className=\"text-dark-400 text-sm\">总任务数</p>\n              <p className=\"text-xl font-bold text-white\">\n                {agents.reduce((sum, a) => sum + a.tasksCompleted, 0).toLocaleString()}\n              </p>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      {/* Filters */}\n      <div className=\"flex flex-col sm:flex-row gap-4\">\n        <div className=\"relative flex-1\">\n          <Search className=\"absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-dark-500\" />\n          <input\n            type=\"text\"\n            placeholder=\"搜索员工...\"\n            value={searchQuery}\n            onChange={(e) => setSearchQuery(e.target.value)}\n            className=\"w-full bg-dark-900 border border-dark-800 rounded-lg pl-10 pr-4 py-2.5 text-sm placeholder:text-dark-500 focus:outline-none focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500/50\"\n          />\n        </div>\n        <div className=\"flex items-center gap-2\">\n          <Filter className=\"w-4 h-4 text-dark-400\" />\n          <select\n            value={statusFilter}\n            onChange={(e) => setStatusFilter(e.target.value)}\n            className=\"bg-dark-900 border border-dark-800 rounded-lg px-4 py-2.5 text-sm text-dark-200 focus:outline-none focus:ring-2 focus:ring-primary-500/20\"\n          >\n            <option value=\"all\">全部状态</option>\n            <option value=\"active\">运行中</option>\n            <option value=\"idle\">待机</option>\n            <option value=\"paused\">已暂停</option>\n          </select>\n        </div>\n      </div>\n\n      {/* Agents Grid */}\n      <div className=\"grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4\">\n        {filteredAgents.map((agent) => {\n          const TypeIcon = typeIcons[agent.type] || Bot\n          return (\n            <div\n              key={agent.id}\n              className=\"bg-dark-900 border border-dark-800 rounded-xl p-5 hover:border-dark-700 transition-all group\"\n            >\n              {/* Header */}\n              <div className=\"flex items-start justify-between mb-4\">\n                <div className=\"flex items-center gap-3\">\n                  <div className={`w-12 h-12 rounded-xl flex items-center justify-center border ${typeColors[agent.type]}`}>\n                    <TypeIcon className=\"w-6 h-6\" />\n                  </div>\n                  <div>\n                    <h3 className=\"font-semibold text-white\">{agent.name}</h3>\n                    <p className=\"text-dark-400 text-sm\">{agent.role}</p>\n                  </div>\n                </div>\n                <div className=\"flex items-center gap-1\">\n                  <button className=\"p-1.5 hover:bg-dark-800 rounded-lg transition-colors opacity-0 group-hover:opacity-100\">\n                    <Edit className=\"w-4 h-4 text-dark-400\" />\n                  </button>\n                  <button className=\"p-1.5 hover:bg-dark-800 rounded-lg transition-colors opacity-0 group-hover:opacity-100\">\n                    <MoreHorizontal className=\"w-4 h-4 text-dark-400\" />\n                  </button>\n                </div>\n              </div>\n\n              {/* Description */}\n              <p className=\"text-dark-400 text-sm mb-4 line-clamp-2\">\n                {agent.description}\n              </p>\n\n              {/* Stats */}\n              <div className=\"grid grid-cols-2 gap-3 mb-4\">\n                <div className=\"bg-dark-800/50 rounded-lg p-3\">\n                  <p className=\"text-dark-500 text-xs\">完成任务</p>\n                  <p className=\"text-white font-medium\">{agent.tasksCompleted.toLocaleString()}</p>\n                </div>\n                <div className=\"bg-dark-800/50 rounded-lg p-3\">\n                  <p className=\"text-dark-500 text-xs\">成功率</p>\n                  <p className=\"text-green-400 font-medium\">{agent.successRate}%</p>\n                </div>\n              </div>\n\n              {/* Capabilities */}\n              <div className=\"flex flex-wrap gap-1.5 mb-4\">\n                {agent.capabilities.map((cap) => (\n                  <span\n                    key={cap}\n                    className=\"px-2 py-0.5 bg-dark-800 text-dark-300 text-xs rounded-full\"\n                  >\n                    {cap}\n                  </span>\n                ))}\n              </div>\n\n              {/* Footer */}\n              <div className=\"flex items-center justify-between pt-4 border-t border-dark-800\">\n                <div className=\"flex items-center gap-2\">\n                  <span\n                    className={`w-2 h-2 rounded-full ${\n                      agent.status === 'active'\n                        ? 'bg-green-500'\n                        : agent.status === 'idle'\n                        ? 'bg-yellow-500'\n                        : 'bg-red-500'\n                    }`}\n                  />\n                  <span className=\"text-dark-400 text-sm\">\n                    {agent.status === 'active'\n                      ? '运行中'\n                      : agent.status === 'idle'\n                      ? '待机'\n                      : '已暂停'}\n                  </span>\n                </div>\n                <div className=\"flex items-center gap-1\">\n                  {agent.status === 'active' ? (\n                    <button className=\"p-1.5 hover:bg-dark-800 rounded-lg transition-colors\">\n                      <Pause className=\"w-4 h-4 text-dark-400\" />\n                    </button>\n                  ) : (\n                    <button className=\"p-1.5 hover:bg-dark-800 rounded-lg transition-colors\">\n                      <Play className=\"w-4 h-4 text-dark-400\" />\n                    </button>\n                  )}\n                  <button className=\"p-1.5 hover:bg-dark-800 rounded-lg transition-colors\">\n                    <Settings className=\"w-4 h-4 text-dark-400\" />\n                  </button>\n                </div>\n              </div>\n            </div>\n          )\n        })}\n      </div>\n\n      {/* Empty State */}\n      {filteredAgents.length === 0 && (\n        <div className=\"text-center py-16\">\n          <div className=\"w-16 h-16 bg-dark-800 rounded-full flex items-center justify-center mx-auto mb-4\">\n            <Search className=\"w-8 h-8 text-dark-500\" />\n          </div>\n          <h3 className=\"text-white font-medium mb-1\">未找到员工</h3>\n          <p className=\"text-dark-400 text-sm\">尝试调整搜索条件或筛选器</p>\n        </div>\n      )}\n    </div>\n  )\n}","file_path":"C:/Users/Administrator/.openclaw/workspace/control-center/src/pages/Agents.tsx"}}],"api":"openai-completions","provider":"moonshot","model":"kimi-k2.5","usage":{"input":1522,"output":3415,"cacheRead":40448,"cacheWrite":0,"totalTokens":45385,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773760836290}}
