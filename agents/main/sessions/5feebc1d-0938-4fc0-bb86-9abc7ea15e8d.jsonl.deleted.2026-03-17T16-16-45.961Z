{"type":"message","id":"d6b290a7","parentId":"c3ef1948","timestamp":"2026-03-17T15:28:49.435Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"write:15","name":"write","arguments":{"content":"import { useState } from 'react'\nimport {\n  CheckSquare,\n  Plus,\n  Search,\n  Filter,\n  Calendar,\n  Clock,\n  User,\n  MoreHorizontal,\n  Play,\n  Pause,\n  CheckCircle,\n  XCircle,\n  AlertCircle,\n  ArrowRight,\n  Flag,\n  Tag\n} from 'lucide-react'\n\nconst taskStats = {\n  total: 156,\n  pending: 23,\n  inProgress: 12,\n  completed: 121,\n}\n\nconst tasks = [\n  {\n    id: 1,\n    title: '完成控制面板 UI 设计',\n    description: '设计 OpenClaw 控制面板的用户界面，包括深色主题和响应式布局',\n    status: 'in_progress',\n    priority: 'high',\n    assignee: 'Jarvis',\n    dueDate: '2024-03-18',\n    progress: 65,\n    tags: ['UI设计', '前端'],\n  },\n  {\n    id: 2,\n    title: 'API 接口性能优化',\n    description: '优化用户查询接口的响应时间，目标 < 100ms',\n    status: 'pending',\n    priority: 'high',\n    assignee: 'TARS',\n    dueDate: '2024-03-20',\n    progress: 0,\n    tags: ['后端', '性能优化'],\n  },\n  {\n    id: 3,\n    title: '数据分析报告生成',\n    description: '生成 Q1 用户行为分析报告',\n    status: 'completed',\n    priority: 'medium',\n    assignee: 'Friday',\n    dueDate: '2024-03-15',\n    progress: 100,\n    tags: ['数据分析', '报告'],\n  },\n  {\n    id: 4,\n    title: '文档整理与归档',\n    description: '整理技术文档并归档到知识库',\n    status: 'in_progress',\n    priority: 'low',\n    assignee: 'Alfred',\n    dueDate: '2024-03-22',\n    progress: 40,\n    tags: ['文档', '整理'],\n  },\n  {\n    id: 5,\n    title: '多语言翻译支持',\n    description: '添加中文、日文、德文界面支持',\n    status: 'pending',\n    priority: 'medium',\n    assignee: 'C-3PO',\n    dueDate: '2024-03-25',\n    progress: 0,\n    tags: ['国际化', '翻译'],\n  },\n  {\n    id: 6,\n    title: '系统安全审计',\n    description: '进行季度安全审计，检查潜在漏洞',\n    status: 'completed',\n    priority: 'high',\n    assignee: 'TARS',\n    dueDate: '2024-03-10',\n    progress: 100,\n    tags: ['安全', '审计'],\n  },\n]\n\nconst statusConfig = {\n  pending: { label: '待处理', color: 'bg-yellow-500/10 text-yellow-400 border-yellow-500/20', icon: Clock },\n  in_progress: { label: '进行中', color: 'bg-blue-500/10 text-blue-400 border-blue-500/20', icon: Play },\n  completed: { label: '已完成', color: 'bg-green-500/10 text-green-400 border-green-500/20', icon: CheckCircle },\n  cancelled: { label: '已取消', color: 'bg-red-500/10 text-red-400 border-red-500/20', icon: XCircle },\n}\n\nconst priorityConfig = {\n  high: { label: '高', color: 'text-red-400', icon: Flag },\n  medium: { label: '中', color: 'text-orange-400', icon: Flag },\n  low: { label: '低', color: 'text-green-400', icon: Flag },\n}\n\nexport default function Tasks() {\n  const [searchQuery, setSearchQuery] = useState('')\n  const [statusFilter, setStatusFilter] = useState('all')\n  const [selectedTasks, setSelectedTasks] = useState<number[]>([])\n\n  const filteredTasks = tasks.filter((task) => {\n    const matchesSearch = task.title.toLowerCase().includes(searchQuery.toLowerCase()) ||\n      task.description.toLowerCase().includes(searchQuery.toLowerCase())\n    const matchesStatus = statusFilter === 'all' || task.status === statusFilter\n    return matchesSearch && matchesStatus\n  })\n\n  const toggleTaskSelection = (id: number) => {\n    setSelectedTasks((prev) =>\n      prev.includes(id) ? prev.filter((t) => t !== id) : [...prev, id]\n    )\n  }\n\n  return (\n    <div className=\"space-y-6\">\n      {/* Header */}\n      <div className=\"flex items-center justify-between\">\n        <div>\n          <h1 className=\"text-2xl font-bold text-white\">任务 Tasks</h1>\n          <p className=\"text-dark-400 mt-1\">管理和跟踪团队任务进度</p>\n        </div>\n        <button className=\"flex items-center gap-2 bg-primary-600 hover:bg-primary-700 text-white px-4 py-2 rounded-lg transition-colors\">\n          <Plus className=\"w-4 h-4\" />\n          <span>新建任务</span>\n        </button>\n      </div>\n\n      {/* Stats */}\n      <div className=\"grid grid-cols-2 sm:grid-cols-4 gap-4\">\n        <div className=\"bg-dark-900 border border-dark-800 rounded-xl p-5\">\n          <div className=\"flex items-center gap-3\">\n            <div className=\"p-3 bg-dark-800 rounded-xl\">\n              <CheckSquare className=\"w-5 h-5 text-primary-400\" />\n            </div>\n            <div>\n              <p className=\"text-dark-400 text-sm\">总任务</p>\n              <p className=\"text-xl font-bold text-white\">{taskStats.total}</p>\n            </div>\n          </div>\n        </div>\n        <div className=\"bg-dark-900 border border-dark-800 rounded-xl p-5\">\n          <div className=\"flex items-center gap-3\">\n            <div className=\"p-3 bg-yellow-500/10 rounded-xl\">\n              <Clock className=\"w-5 h-5 text-yellow-400\" />\n            </div>\n            <div>\n              <p className=\"text-dark-400 text-sm\">待处理</p>\n              <p className=\"text-xl font-bold text-white\">{taskStats.pending}</p>\n            </div>\n          </div>\n        </div>\n        <div className=\"bg-dark-900 border border-dark-800 rounded-xl p-5\">\n          <div className=\"flex items-center gap-3\">\n            <div className=\"p-3 bg-blue-500/10 rounded-xl\">\n              <Play className=\"w-5 h-5 text-blue-400\" />\n            </div>\n            <div>\n              <p className=\"text-dark-400 text-sm\">进行中</p>\n              <p className=\"text-xl font-bold text-white\">{taskStats.inProgress}</p>\n            </div>\n          </div>\n        </div>\n        <div className=\"bg-dark-900 border border-dark-800 rounded-xl p-5\">\n          <div className=\"flex items-center gap-3\">\n            <div className=\"p-3 bg-green-500/10 rounded-xl\">\n              <CheckCircle className=\"w-5 h-5 text-green-400\" />\n            </div>\n            <div>\n              <p className=\"text-dark-400 text-sm\">已完成</p>\n              <p className=\"text-xl font-bold text-white\">{taskStats.completed}</p>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      {/* Filters */}\n      <div className=\"flex flex-col sm:flex-row gap-4\">\n        <div className=\"relative flex-1\">\n          <Search className=\"absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-dark-500\" />\n          <input\n            type=\"text\"\n            placeholder=\"搜索任务...\"\n            value={searchQuery}\n            onChange={(e) => setSearchQuery(e.target.value)}\n            className=\"w-full bg-dark-900 border border-dark-800 rounded-lg pl-10 pr-4 py-2.5 text-sm placeholder:text-dark-500 focus:outline-none focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500/50\"\n          />\n        </div>\n        <div className=\"flex items-center gap-2\">\n          <Filter className=\"w-4 h-4 text-dark-400\" />\n          <select\n            value={statusFilter}\n            onChange={(e) => setStatusFilter(e.target.value)}\n            className=\"bg-dark-900 border border-dark-800 rounded-lg px-4 py-2.5 text-sm text-dark-200 focus:outline-none focus:ring-2 focus:ring-primary-500/20\"\n          >\n            <option value=\"all\">全部状态</option>\n            <option value=\"pending\">待处理</option>\n            <option value=\"in_progress\">进行中</option>\n            <option value=\"completed\">已完成</option>\n          </select>\n        </div>\n      </div>\n\n      {/* Task List */}\n      <div className=\"space-y-3\">\n        {filteredTasks.map((task) => {\n          const StatusIcon = statusConfig[task.status as keyof typeof statusConfig].icon\n          const PriorityIcon = priorityConfig[task.priority as keyof typeof priorityConfig].icon\n          return (\n            <div\n              key={task.id}\n              className=\"bg-dark-900 border border-dark-800 rounded-xl p-5 hover:border-dark-700 transition-all group\"\n            >\n              <div className=\"flex items-start gap-4\">\n                {/* Checkbox */}\n                <input\n                  type=\"checkbox\"\n                  checked={selectedTasks.includes(task.id)}\n                  onChange={() => toggleTaskSelection(task.id)}\n                  className=\"mt-1 w-4 h-4 rounded border-dark-600 bg-dark-800 text-primary-600 focus:ring-primary-500/20\"\n                />\n\n                {/* Content */}\n                <div className=\"flex-1 min-w-0\">\n                  <div className=\"flex items-start justify-between gap-4\">\n                    <div>\n                      <div className=\"flex items-center gap-2 mb-1\">\n                        <h3 className=\"font-medium text-white group-hover:text-primary-400 transition-colors\">\n                          {task.title}\n                        </h3>\n                        <span className={`px-2 py-0.5 rounded-full text-xs border ${statusConfig[task.status as keyof typeof statusConfig].color}`}>\n                          <span className=\"flex items-center gap-1\">\n                            <StatusIcon className=\"w-3 h-3\" />\n                            {statusConfig[task.status as keyof typeof statusConfig].label}\n                          </span>\n                        </span>\n                      </div>\n                      <p className=\"text-dark-400 text-sm\">{task.description}</p>\n                    </div>\n                    <div className=\"flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity\">\n                      <button className=\"p-1.5 hover:bg-dark-800 rounded-lg transition-colors\">\n                        <Play className=\"w-4 h-4 text-dark-400\" />\n                      </button>\n                      <button className=\"p-1.5 hover:bg-dark-800 rounded-lg transition-colors\">\n                        <CheckCircle className=\"w-4 h-4 text-dark-400\" />\n                      </button>\n                      <button className=\"p-1.5 hover:bg-dark-800 rounded-lg transition-colors\">\n                        <MoreHorizontal className=\"w-4 h-4 text-dark-400\" />\n                      </button>\n                    </div>\n                  </div>\n\n                  {/* Meta */}\n                  <div className=\"flex items-center gap-4 mt-4\">\n                    <div className=\"flex items-center gap-1.5 text-dark-400 text-sm\">\n                      <div className=\"w-6 h-6 bg-gradient-to-br from-primary-500 to-purple-600 rounded-full flex items-center justify-center\">\n                        <span className=\"text-white text-xs\">{task.assignee[0]}</span>\n                      </div>\n                      <span>{task.assignee}</span>\n                    </div>\n                    <div className=\"flex items-center gap-1.5 text-dark-400 text-sm\">\n                      <Calendar className=\"w-4 h-4\" />\n                      <span>{task.dueDate}</span>\n                    </div>\n                    <div className={`flex items-center gap-1 text-sm ${priorityConfig[task.priority as keyof typeof priorityConfig].color}`}>\n                      <PriorityIcon className=\"w-4 h-4\" />\n                      <span>{priorityConfig[task.priority as keyof typeof priorityConfig].label}优先级</span>\n                    </div>\n                    <div className=\"flex items-center gap-1.5\">\n                      {task.tags.map((tag) => (\n                        <span\n                          key={tag}\n                          className=\"px-2 py-0.5 bg-dark-800 text-dark-400 text-xs rounded-full\"\n                        >\n                          {tag}\n                        </span>\n                      ))}\n                    </div>\n                  </div>\n\n                  {/* Progress */}\n                  {task.status === 'in_progress' && (\n                    <div className=\"mt-4\">\n                      <div className=\"flex items-center justify-between text-xs mb-1\">\n                        <span className=\"text-dark-400\">进度</span>\n                        <span className=\"text-white\">{task.progress}%</span>\n                      </div>\n                      <div className=\"h-2 bg-dark-800 rounded-full overflow-hidden\">\n                        <div\n                          className=\"h-full bg-primary-500 rounded-full transition-all\"\n                          style={{ width: `${task.progress}%` }}\n                        />\n                      </div>\n                    </div>\n                  )}\n                </div>\n              </div>\n            </div>\n          )\n        })}\n      </div>\n\n      {/* Empty State */}\n      {filteredTasks.length === 0 && (\n        <div className=\"text-center py-16\">\n          <div className=\"w-16 h-16 bg-dark-800 rounded-full flex items-center justify-center mx-auto mb-4\">\n            <CheckSquare className=\"w-8 h-8 text-dark-500\" />\n          </div>\n          <h3 className=\"text-white font-medium mb-1\">暂无任务</h3>\n          <p className=\"text-dark-400 text-sm\">创建一个新任务开始工作</p>\n        </div>\n      )}\n    </div>\n  )\n}","file_path":"C:/Users/Administrator/.openclaw/workspace/control-center/src/pages/Tasks.tsx"}}],"api":"openai-completions","provider":"moonshot","model":"kimi-k2.5","usage":{"input":1557,"output":3536,"cacheRead":54528,"cacheWrite":0,"totalTokens":59621,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773761224753}}
