{"type":"message","id":"401bdb42","parentId":"9d3aafc3","timestamp":"2026-03-17T05:14:08.946Z","message":{"role":"toolResult","toolCallId":"read:207","toolName":"read","content":[{"type":"text","text":"            \"status\": \"offline\",\n            \"pid\": None,\n            \"lastActive\": None,\n            \"sessions\": 0\n        }\n        \n        # 检查 PID 文件\n        pid_file = agent_dir / \"agent.pid\"\n        if pid_file.exists():\n            try:\n                with open(pid_file, 'r') as f:\n                    pid = int(f.read().strip())\n                    if psutil.pid_exists(pid):\n                        status[\"status\"] = \"online\"\n                        status[\"pid\"] = pid\n                        proc = psutil.Process(pid)\n                        status[\"lastActive\"] = datetime.fromtimestamp(\n                            proc.create_time()\n                        ).isoformat()\n            except Exception:\n                pass\n        \n        # 统计会话数\n        sessions_dir = agent_dir / \"sessions\"\n        if sessions_dir.exists():\n            status[\"sessions\"] = len([s for s in sessions_dir.iterdir() if s.is_dir()])\n        \n        return jsonify({\n            \"success\": True,\n            \"data\": status\n        })\n        \n    except Exception as e:\n        return jsonify({\n            \"success\": False,\n            \"error\": str(e)\n        }), 500\n\n\n@app.route('/api/agents/<agent_id>/<action>', methods=['POST'])\ndef control_agent(agent_id, action):\n    \"\"\"控制 Agent（启动/停止/重启）\"\"\"\n    valid_actions = ['start', 'stop', 'restart', 'chat']\n    \n    if action not in valid_actions:\n        return jsonify({\n            \"success\": False,\n            \"error\": f\"Invalid action. Valid actions: {', '.join(valid_actions)}\"\n        }), 400\n    \n    try:\n        if action == \"chat\":\n            # 切换到指定 Agent - 使用 openclaw agent --local 模式\n            # 先检查 Agent 配置是否存在\n            agent_dir = AGENTS_DIR / agent_id\n            if not agent_dir.exists():\n                return jsonify({\n                    \"success\": False,\n                    \"error\": f\"Agent {agent_id} 配置不存在\"\n                }), 404\n\n[187 more lines in file. Use offset=240 to continue.]"}],"isError":false,"timestamp":1773724448941}}
