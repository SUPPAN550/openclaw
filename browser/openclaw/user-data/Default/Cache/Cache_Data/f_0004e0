mOut="138240000" volume="0.0" speed="1.0" noAudio="true"><videoFxs><videoFx index="0" type="property" name="" id="" intensity="1.0"><fxParams><fxParam type="float" key="Scale X" value="1"/><fxParam type="float" key="Scale Y" value="1"/><fxParam type="float" key="Rotation" value="0"/><fxParam type="float" key="Trans X" value="0"/><fxParam type="float" key="Trans Y" value="0"/><fxParam type="float" key="Opacity" value="1"/><fxParam type="float" key="Anchor X" value="0"/><fxParam type="float" key="Anchor Y" value="0"/><fxParam type="float" key="Scan Value" value="0"/><fxParam type="menu" key="Fill Mode" value="AspectFit"/><fxParam type="menu" key="Background Mode" value="Image File"/><fxParam type="color" key="Background Color" value="#00000000"/><fxParam type="string" key="Background Image" value="https://aigcrender.cdn.bcebos.com/aigcrender/vrender/material/2023-02-15/3b3194f0f7b7129b69c2b466d1530689.png" resourceUrl="https://aigcrender.cdn.bcebos.com/aigcrender/vrender/material/2023-02-15/3b3194f0f7b7129b69c2b466d1530689.png"/></fxParams></videoFx></videoFxs><extraInfo batchEdit="true" digitalId="" resType="video" ttsId="" mid="15893057304685103648" startTime="135240000" endTime="138240000"/></video></videos></videoTrack></videoTracks><audioTracks><audioTrack volume="1.0" index="1" show="true"><audios><audio id="14151640" path="https://baidu-aigc.cdn.bcebos.com/task/65665db6fb08b69651d4d25e8998a0a3f345457e.wav" inPoint="0" outPoint="3636400" trimIn="0" trimOut="3636400" volume="1.0" speed="1.0" combination="true" combinationOrder="1"><extraInfo batchEdit="true" digitalId="" ttsId="4125" text="兄弟们，今天给你们讲一部98年的老恐怖片——《阴阳路》。"/></audio><audio id="14151618" path="https://baidu-aigc.cdn.bcebos.com/task/e9e84866fb616e53b7b88773c563bb59fb0fafb7.wav" inPoint="3636400" outPoint="5536400" trimIn="0" trimOut="1900000" volume="1.0" speed="1.0" combination="true" combinationOrder="2"><extraInfo batchEdit="true" digitalId="" ttsId="4125" text="故事要从四个年轻人说起。"/></audio><audio id="14151634" path="https://baidu-aigc.cdn.bcebos.com/task/e5cd2e001c4436edc5deebd9162cbd531bb5a238.wav" inPoint="5536400" outPoint="9236400" trimIn="0" trimOut="3700000" volume="1.0" speed="1.0" combination="true" combinationOrder="3"><extraInfo batchEdit="true" digitalId="" ttsId="4125" text="阿豪、阿强、阿荣和珠珠，四个人开着车去郊外野营。"/></audio><audio id="14151628" path="https://baidu-aigc.cdn.bcebos.com/task/e989c5a8a85afac1a1b141f3c70e7375eac80748.wav" inPoint="9236400" outPoint="11654600" trimIn="0" trimOut="2418200" volume="1.0" speed="1.0" combination="true" combinationOrder="4"><extraInfo batchEdit="true" digitalId="" ttsId="4125" text="但他们不知道，这条路，是阴阳路。"/></audio><audio id="14151621" path="https://baidu-aigc.cdn.bcebos.com/task/38cfde2d51b9f910afecc5b456ea80c32e849856.wav" inPoint="11654600" outPoint="14636400" trimIn="0" trimOut="2981799" volume="1.0" speed="1.0" combination="true" combinationOrder="5"><extraInfo batchEdit="true" digitalId="" ttsId="4125" text="晚上开车的时候，阿豪看到一个女生站在路边哭。"/></audio><audio id="14151624" path="https://baidu-aigc.cdn.bcebos.com/task/4fc6e481148752d7c4e3b1a6ecf5474f70aa4b15.wav" inPoint="14636400" outPoint="16736400" trimIn="0" trimOut="2100000" volume="1.0" speed="1.0" combination="true" combinationOrder="6"><extraInfo batchEdit="true" digitalId="" ttsId="4125" text="他于心不忍停车想要载她一程。"/></audio><audio id="14151645" path="https://baidu-aigc.cdn.bcebos.com/task/b78041a09d89f4971f2169a215d59df0743bafdf.wav" inPoint="16736400" outPoint="19054600" trimIn="0" trimOut="2318200" volume="1.0" speed="1.0" combination="true" combinationOrder="7"><extraInfo batchEdit="true" digitalId="" ttsId="4125" text="但诡异的是，后视镜里根本没人！"/></audio><audio id="14151619" path="https://baidu-aigc.cdn.bcebos.com/task/6706fc25a5d34ccc817f7136dbd081f741a873bd.wav" inPoint="19054600" outPoint="20691000" trimIn="0" trimOut="1636400" volume="1.0" speed="1.0" combination="true" combinationOrder="8"><extraInfo batchEdit="true" digitalId="" ttsId="4125" text="兄弟，你眼花了吧？"/></audio><audio id="14151641" path="https://baidu-aigc.cdn.bcebos.com/task/bb3f04b640579ec4425a22293d22ddd0710f69d8.wav" inPoint="20691000" outPoint="23100100" trimIn="0" trimOut="2409100" volume="1.0" speed="1.0" combination="true" combinationOrder="9"><extraInfo batchEdit="true" digitalId="" ttsId="4125" text="阿豪揉了揉眼睛，确实没人啊。"/></audio><audio id="14151630" path="https://baidu-aigc.cdn.bcebos.com/task/de7e695022cff1171425251be25b1be6bdc203af.wav" inPoint="23100100" outPoint="25409300" trimIn="0" trimOut="2309200" volume="1.0" speed="1.0" combination="true" combinationOrder="10"><extraInfo batchEdit="true" digitalId="" ttsId="4125" text="可他明明看到一个穿着红衣服的女人。"/></audio><audio id="14151635" path="https://baidu-aigc.cdn.bcebos.com/task/26bac0c84241b7956e91dc5568c4c2f62f49e2d8.wav" inPoint="25409300" outPoint="28545600" trimIn="0" trimOut="3136300" volume="1.0" speed="1.0" combination="true" combinationOrder="11"><extraInfo batchEdit="true" digitalId="" ttsId="4125" text="当天晚上，他们在附近发现了一间废弃的屋子。"/></audio><audio id="14151638" path="https://baidu-aigc.cdn.bcebos.com/task/7e15a34847c2184e3d00d986a7ccd705a7f27092.wav" inPoint="28545600" outPoint="30036600" trimIn="0" trimOut="1491000" volume="1.0" speed="1.0" combination="true" combinationOrder="12"><extraInfo batchEdit="true" digitalId="" ttsId="4125" text="四个人决定进去探险。"/></audio><audio id="14151616" path="https://baidu-aigc.cdn.bcebos.com/task/1e8a71426063879a14973f8db52a40bcd4553e46.wav" inPoint="30036600" outPoint="32000200" trimIn="0" trimOut="1963600" volume="1.0" speed="1.0" combination="true" combinationOrder="13"><extraInfo batchEdit="true" digitalId="" ttsId="4125" text="但这一进去，就出不来了。"/></audio><audio id="14151639" path="https://baidu-aigc.cdn.bcebos.com/task/8abf439f40b2fb972f084431827a354baad5796c.wav" inPoint="32000200" outPoint="34727500" trimIn="0" trimOut="2727300" volume="1.0" speed="1.0" combination="true" combinationOrder="14"><extraInfo batchEdit="true" digitalId="" ttsId="4125" text="屋子里有红衣女、有纸人、还有。"/></audio><audio id="14151650" path="https://baidu-aigc.cdn.bcebos.com/task/6c7ca034a07208bbef028a32a3f75973ce7af6c0.wav" inPoint="34727500" outPoint="38982100" trimIn="0" trimOut="4254600" volume="1.0" speed="1.0" combination="true" combinationOrder="15"><extraInfo batchEdit="true" digitalId="" ttsId="4125" text="最恐怖的是，第二天一早，阿强发现自己的朋友，一个接一个地消失了。"/></audio><audio id="14151649" path="https://baidu-aigc.cdn.bcebos.com/task/e92e98985314aeb23a3f6aa0a9755a126e76f113.wav" inPoint="38982100" outPoint="40809400" trimIn="0" trimOut="1827300" volume="1.0" speed="1.0" combination="true" combinationOrder="16"><extraInfo batchEdit="true" digitalId="" ttsId="4125" text="到最后，只剩下他一个人。"/></audio><audio id="14151626" path="https://baidu-aigc.cdn.bcebos.com/task/c2aaf51a8dae5da5bc0340a0a5e41b78bb2bb8cb.wav" inPoint="40809399" outPoint="42791299" trimIn="0" trimOut="1981900" volume="1.0" speed="1.0" combination="true" combinationOrder="17"><extraInfo batchEdit="true" digitalId="" ttsId="4125" text="而那个红衣女，就站在他身后。"/></audio><audio id="14151627" path="https://baidu-aigc.cdn.bcebos.com/task/0459e7823414bd2e06a3bf8b743265c7db70b837.wav" inPoint="42791300" outPoint="44409400" trimIn="0" trimOut="1618100" volume="1.0" speed="1.0" combination="true" combinationOrder="18"><extraInfo batchEdit="true" digitalId="" ttsId="4125" text="你以为这是鬼故事？"/></audio><audio id="14151648" path="https://baidu-aigc.cdn.bcebos.com/task/705027a23e10762c81ae3b36e2e919af213c25be.wav" inPoint="44409400" outPoint="45018600" trimIn="0" trimOut="609199" volume="1.0" speed="1.0" combination="true" combinationOrder="19"><extraInfo batchEdit="true" digitalId="" ttsId="4125" text="错了。"/></audio><audio id="14151646" path="https://baidu-aigc.cdn.bcebos.com/task/0c295a0ae5beeb30fe9b8b8274adec2b2d493dbc.wav" inPoint="45018600" outPoint="47045900" trimIn="0" trimOut="2027300" volume="1.0" speed="1.0" combination="true" combinationOrder="20"><extraInfo batchEdit="true" digitalId="" ttsId="4125" text="其实这一切，都是阿豪的阴谋。"/></audio><audio id="14151633" path="https://baidu-aigc.cdn.bcebos.com/task/45c6c18b75988ab1d034ee7d0d4da3e5ed85d2a0.wav" inPoint="47045900" outPoint="49582300" trimIn="0" trimOut="2536400" volume="1.0" speed="1.0" combination="true" combinationOrder="21"><extraInfo batchEdit="true" digitalId="" ttsId="4125" text="他早就想害死这三个朋友，独吞他们的钱。"/></audio><audio id="14151629" path="https://baidu-aigc.cdn.bcebos.com/task/61cfac735373c3c00820941caeb2a40a7025762a.wav" inPoint="49582299" outPoint="51745899" trimIn="0" trimOut="2163600" volume="1.0" speed="1.0" combination="true" combinationOrder="22"><extraInfo batchEdit="true" digitalId="" ttsId="4125" text="而那个红衣女，是他找来的演员。"/></audio><audio id="14151642" path="https://baidu-aigc.cdn.bcebos.com/task/75b1e63f8cc5d356b003c3f19e02ae7ff9ac8967.wav" inPoint="51745900" outPoint="54273200" trimIn="0" trimOut="2527299" volume="1.0" speed="1.0" combination="true" combinationOrder="23"><extraInfo batchEdit="true" digitalId="" ttsId="4125" text="但最后，真正的恶鬼，还是找上了他。"/></audio><audio id="14151620" path="https://baidu-aigc.cdn.bcebos.com/task/81bda583f1fe76519d8bd31f64be96ebfa06691a.wav" inPoint="54273200" outPoint="57645941" trimIn="0" trimOut="3372741" volume="1.0" speed="1.0" combination="true" combinationOrder="24"><extraInfo batchEdit="true" digitalId="" ttsId="4125" text="兄弟们，这个故事告诉我们——比鬼更可怕的，是人心。"/></audio></audios></audioTrack><audioTrack volume="1.0" index="0" show="true"><audios><audio id="10097103" path="https://aigcrender.bj.bcebos.com/aigcrender/voiceop/230323/cb35548c1da8c37e47297a68d8070a21.mp3" inPoint="0" outPoint="57645941" trimIn="0" trimOut="57645941" volume="1.0" speed="1.0" combination="false" combinationOrder="0"><extraInfo batchEdit="false" digitalId="" ttsId="" bgmName="bgm836"/></audio></audios></audioTrack></audioTracks><captionTracks><captionTrack index="4" show="true"><caption type="modular" text="兄弟们，今天给你们讲一部98年的老" inPoint="0" duration="2289585" translationX="0.0" translationY="-860.0" font="Noto Sans CJK SC [NotoSansCJKsc-Regular]" fontSizeRatio="0.03125" weight="400" alig