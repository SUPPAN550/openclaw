{"type":"message","id":"3f2c310b","parentId":"d748c9cc","timestamp":"2026-03-17T03:54:51.133Z","message":{"role":"toolResult","toolCallId":"read:120","toolName":"read","content":[{"type":"text","text":"                if (action === 'webui' && result.url) {\n                    window.open(result.url, '_blank');\n                }\n            } else {\n                showNotification(`操作失败: ${result.error || '未知错误'}`, 5000);\n            }\n        } catch (error) {\n            console.error('控制操作失败:', error);\n            showNotification(`操作失败: ${error.message}`, 5000);\n        }\n    });\n}\n\n// ===== 切换沙箱模式 =====\nasync function toggleSandboxMode() {\n    try {\n        // 先获取当前状态\n        const response = await fetch(`${API_BASE_URL}/sandbox`);\n        const result = await response.json();\n        \n        const currentEnabled = result.success ? result.enabled : false;\n        const newEnabled = !currentEnabled;\n        \n        // 切换状态\n        const toggleResponse = await fetch(`${API_BASE_URL}/sandbox`, {\n            method: 'POST',\n            headers: { 'Content-Type': 'application/json' },\n            body: JSON.stringify({ enabled: newEnabled })\n        });\n        \n        const toggleResult = await toggleResponse.json();\n        \n        if (toggleResult.success) {\n            showNotification(`沙箱模式已${newEnabled ? '启用' : '禁用'}`);\n        } else {\n            showNotification(`切换沙箱模式失败: ${toggleResult.error || '未知错误'}`, 5000);\n        }\n    } catch (error) {\n        console.error('切换沙箱模式失败:', error);\n        showNotification(`切换沙箱模式失败: ${error.message}`, 5000);\n    }\n}\n\n// ===== 进入对话 =====\nfunction enterChat(agentId) {\n    const agent = agentsData.find(a => a.id === agentId);\n    if (!agent) return;\n    \n    showNotification(`正在进入 ${agent.displayName} 对话...`);\n    window.open(`http://127.0.0.1:18789/chat/${agentId}`, '_blank');\n\n[27 more lines in file. Use offset=600 to continue.]"}],"isError":false,"timestamp":1773