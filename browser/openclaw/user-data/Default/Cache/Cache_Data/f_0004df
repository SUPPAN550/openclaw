inalResUrl":"http://vd3.bdstatic.com/mda-pi4wjhmbz01gmdtt/360p/h264/1693949698218654075/mda-pi4wjhmbz01gmdtt.mp4","disabledStartupTime":61.7},{"type":"video","src":"","start":54.6459,"duration":3,"originalDuration":138.25,"thumbnail":"http://bjh-pixel.bj.bcebos.com/material/f4eac6ae-806c-11ee-ac03-fa2600059b5e.jpg","startupTime":135.25,"offset":0,"mid":"15893057304685103648","relatedId":"","isOriginalSound":0,"assistVolume":0,"cropper":null,"action":null,"source_id":"3","source":"ssearch_query","bgmMuted":false,"watermark":0,"compressed_url":"","width":652,"height":652,"originalResUrl":"http://vd3.bdstatic.com/mda-pka1ce7xu57yw2nd/360p/h264/1699664282240971527/mda-pka1ce7xu57yw2nd.mp4","disabledStartupTime":135.25}],"textList":[{"text":"兄弟们，今天给你们讲一部98年的老恐怖片——《阴阳路》。","start":0,"duration":3.6364,"ttsUrl":"http://baidu-aigc.cdn.bcebos.com/task/65665db6fb08b69651d4d25e8998a0a3f345457e.wav","caption":["兄弟们，今天给你们讲一部98年的老","恐怖片——《阴阳路》。"],"renderCaption":["兄弟们，今天给你们讲一部98年的老","恐怖片——《阴阳路》"],"anchorScene":0,"relatedId":""},{"text":"故事要从四个年轻人说起。","start":3.6364,"duration":1.9,"ttsUrl":"http://baidu-aigc.cdn.bcebos.com/task/e9e84866fb616e53b7b88773c563bb59fb0fafb7.wav","caption":["故事要从四个年轻人说起。"],"renderCaption":["故事要从四个年轻人说起"],"anchorScene":0,"relatedId":""},{"text":"阿豪、阿强、阿荣和珠珠，四个人开着车去郊外野营。","start":5.5364,"duration":3.7,"ttsUrl":"http://baidu-aigc.cdn.bcebos.com/task/e5cd2e001c4436edc5deebd9162cbd531bb5a238.wav","caption":["阿豪、阿强、阿荣和珠珠，","四个人开着车去郊外野营。"],"renderCaption":["阿豪、阿强、阿荣和珠珠","四个人开着车去郊外野营"],"anchorScene":0,"relatedId":""},{"text":"但他们不知道，这条路，是阴阳路。","start":9.2364,"duration":2.4182,"ttsUrl":"http://baidu-aigc.cdn.bcebos.com/task/e989c5a8a85afac1a1b141f3c70e7375eac80748.wav","caption":["但他们不知道，","这条路，是阴阳路。"],"renderCaption":["但他们不知道","这条路，是阴阳路"],"anchorScene":0,"relatedId":""},{"text":"晚上开车的时候，阿豪看到一个女生站在路边哭。","start":11.6546,"duration":2.9818,"ttsUrl":"http://baidu-aigc.cdn.bcebos.com/task/38cfde2d51b9f910afecc5b456ea80c32e849856.wav","caption":["晚上开车的时候，","阿豪看到一个女生站在路边哭。"],"renderCaption":["晚上开车的时候","阿豪看到一个女生站在路边哭"],"anchorScene":0,"relatedId":""},{"text":"他于心不忍停车想要载她一程。","start":14.6364,"duration":2.1,"ttsUrl":"http://baidu-aigc.cdn.bcebos.com/task/4fc6e481148752d7c4e3b1a6ecf5474f70aa4b15.wav","caption":["他于心不忍停车想要载她一程。"],"renderCaption":["他于心不忍停车想要载她一程"],"anchorScene":0,"relatedId":""},{"text":"但诡异的是，后视镜里根本没人！","start":16.7364,"duration":2.3182,"ttsUrl":"http://baidu-aigc.cdn.bcebos.com/task/b78041a09d89f4971f2169a215d59df0743bafdf.wav","caption":["但诡异的是，","后视镜里根本没人！"],"renderCaption":["但诡异的是","后视镜里根本没人"],"anchorScene":0,"relatedId":""},{"text":"兄弟，你眼花了吧？","start":19.0546,"duration":1.6364,"ttsUrl":"http://baidu-aigc.cdn.bcebos.com/task/6706fc25a5d34ccc817f7136dbd081f741a873bd.wav","caption":["兄弟，你眼花了吧？"],"renderCaption":["兄弟，你眼花了吧"],"anchorScene":0,"relatedId":""},{"text":"阿豪揉了揉眼睛，确实没人啊。","start":20.691,"duration":2.4091,"ttsUrl":"http://baidu-aigc.cdn.bcebos.com/task/bb3f04b640579ec4425a22293d22ddd0710f69d8.wav","caption":["阿豪揉了揉眼睛，","确实没人啊。"],"renderCaption":["阿豪揉了揉眼睛","确实没人啊"],"anchorScene":0,"relatedId":""},{"text":"可他明明看到一个穿着红衣服的女人。","start":23.1001,"duration":2.3092,"ttsUrl":"http://baidu-aigc.cdn.bcebos.com/task/de7e695022cff1171425251be25b1be6bdc203af.wav","caption":["可他明明看到一个穿着红衣服的女人。"],"renderCaption":["可他明明看到一个穿着红衣服的女人"],"anchorScene":0,"relatedId":""},{"text":"当天晚上，他们在附近发现了一间废弃的屋子。","start":25.4093,"duration":3.1363000000000003,"ttsUrl":"http://baidu-aigc.cdn.bcebos.com/task/26bac0c84241b7956e91dc5568c4c2f62f49e2d8.wav","caption":["当天晚上，","他们在附近发现了一间废弃的屋子。"],"renderCaption":["当天晚上","他们在附近发现了一间废弃的屋子"],"anchorScene":0,"relatedId":""},{"text":"四个人决定进去探险。","start":28.5456,"duration":1.491,"ttsUrl":"http://baidu-aigc.cdn.bcebos.com/task/7e15a34847c2184e3d00d986a7ccd705a7f27092.wav","caption":["四个人决定进去探险。"],"renderCaption":["四个人决定进去探险"],"anchorScene":0,"relatedId":""},{"text":"但这一进去，就出不来了。","start":30.0366,"duration":1.9636,"ttsUrl":"http://baidu-aigc.cdn.bcebos.com/task/1e8a71426063879a14973f8db52a40bcd4553e46.wav","caption":["但这一进去，","就出不来了。"],"renderCaption":["但这一进去","就出不来了"],"anchorScene":0,"relatedId":""},{"text":"屋子里有红衣女、有纸人、还有。","start":32.0002,"duration":2.7273,"ttsUrl":"http://baidu-aigc.cdn.bcebos.com/task/8abf439f40b2fb972f084431827a354baad5796c.wav","caption":["屋子里有红衣女、有纸人、还有。"],"renderCaption":["屋子里有红衣女、有纸人、还有"],"anchorScene":0,"relatedId":""},{"text":"最恐怖的是，第二天一早，阿强发现自己的朋友，一个接一个地消失了。","start":34.7275,"duration":4.2546,"ttsUrl":"http://baidu-aigc.cdn.bcebos.com/task/6c7ca034a07208bbef028a32a3f75973ce7af6c0.wav","caption":["最恐怖的是，","第二天一早，","阿强发现自己的朋友，","一个接一个地消失了。"],"renderCaption":["最恐怖的是","第二天一早","阿强发现自己的朋友","一个接一个地消失了"],"anchorScene":0,"relatedId":""},{"text":"到最后，只剩下他一个人。","start":38.9821,"duration":1.8273,"ttsUrl":"http://baidu-aigc.cdn.bcebos.com/task/e92e98985314aeb23a3f6aa0a9755a126e76f113.wav","caption":["到最后，只剩下他一个人。"],"renderCaption":["到最后，只剩下他一个人"],"anchorScene":0,"relatedId":""},{"text":"而那个红衣女，就站在他身后。","start":40.8094,"duration":1.9819,"ttsUrl":"http://baidu-aigc.cdn.bcebos.com/task/c2aaf51a8dae5da5bc0340a0a5e41b78bb2bb8cb.wav","caption":["而那个红衣女，","就站在他身后。"],"renderCaption":["而那个红衣女","就站在他身后"],"anchorScene":0,"relatedId":""},{"text":"你以为这是鬼故事？","start":42.7913,"duration":1.6181,"ttsUrl":"http://baidu-aigc.cdn.bcebos.com/task/0459e7823414bd2e06a3bf8b743265c7db70b837.wav","caption":["你以为这是鬼故事？"],"renderCaption":["你以为这是鬼故事"],"anchorScene":0,"relatedId":""},{"text":"错了。","start":44.4094,"duration":0.6092,"ttsUrl":"http://baidu-aigc.cdn.bcebos.com/task/705027a23e10762c81ae3b36e2e919af213c25be.wav","caption":["错了。"],"renderCaption":["错了"],"anchorScene":0,"relatedId":""},{"text":"其实这一切，都是阿豪的阴谋。","start":45.0186,"duration":2.0273000000000003,"ttsUrl":"http://baidu-aigc.cdn.bcebos.com/task/0c295a0ae5beeb30fe9b8b8274adec2b2d493dbc.wav","caption":["其实这一切，","都是阿豪的阴谋。"],"renderCaption":["其实这一切","都是阿豪的阴谋"],"anchorScene":0,"relatedId":""},{"text":"他早就想害死这三个朋友，独吞他们的钱。","start":47.0459,"duration":2.5364,"ttsUrl":"http://baidu-aigc.cdn.bcebos.com/task/45c6c18b75988ab1d034ee7d0d4da3e5ed85d2a0.wav","caption":["他早就想害死这三个朋友，","独吞他们的钱。"],"renderCaption":["他早就想害死这三个朋友","独吞他们的钱"],"anchorScene":0,"relatedId":""},{"text":"而那个红衣女，是他找来的演员。","start":49.5823,"duration":2.1635999999999997,"ttsUrl":"http://baidu-aigc.cdn.bcebos.com/task/61cfac735373c3c00820941caeb2a40a7025762a.wav","caption":["而那个红衣女，","是他找来的演员。"],"renderCaption":["而那个红衣女","是他找来的演员"],"anchorScene":0,"relatedId":""},{"text":"但最后，真正的恶鬼，还是找上了他。","start":51.7459,"duration":2.5273,"ttsUrl":"http://baidu-aigc.cdn.bcebos.com/task/75b1e63f8cc5d356b003c3f19e02ae7ff9ac8967.wav","caption":["但最后，真正的恶鬼，","还是找上了他。"],"renderCaption":["但最后，真正的恶鬼","还是找上了他"],"anchorScene":0,"relatedId":""},{"text":"兄弟们，这个故事告诉我们——比鬼更可怕的，是人心。","start":54.2732,"duration":3.3727416000000003,"ttsUrl":"http://baidu-aigc.cdn.bcebos.com/task/81bda583f1fe76519d8bd31f64be96ebfa06691a.wav","caption":["兄弟们，这个故事告诉我们——比鬼","更可怕的，是人心。"],"renderCaption":["兄弟们，这个故事告诉我们——比鬼","更可怕的，是人心"],"anchorScene":0,"relatedId":""}]},"templateParam":{"bgmUrl":"https://aigcrender.bj.bcebos.com/aigcrender/voiceop/230323/cb35548c1da8c37e47297a68d8070a21.mp3","bgmVol":0.33,"bgmName":"bgm836","bgmAnchorName":"","bgmIcon":"轻松","bgmThumbnail":"","bgmDuration":205.584,"ttsId":"4125","ttsSpd":6,"ttsVol":0.33,"ttsScenario":"","plateType":1},"videoParam":{"videoTitle":"从灵异事件到人性拷问：《阴阳路》揭示人心的黑暗面","videoLongTitle":"从鬼故事到人性揭露：《阴阳路》如何展现人心的阴暗与报应","videoCoverImage":""},"articleParam":{"topic":null,"coverImage":{"widthCover":{"x":0,"y":0,"width":0,"height":0,"url":""},"heightCover":{"x":0,"y":0,"width":0,"height":0,"url":""}},"title":"","publishType":0},"publishParam":{"title":"从灵异事件到人性拷问：《阴阳路》揭示人心的黑暗面","coverImage":"","horiCoverImage":"","size":0,"height":0,"width":0,"videoDuration":0,"videoType":"","mediaid":"","url":"","sourceId":"","source":"saas_manual_pc_v1","publishErrMsg":""},"ext":{"aigc_channel":"","bjh_activity_id":"","generate_type":"PreMediaFill","aigc_generate_type":"PreMediaFill","aigc_from":6,"aigc_type":0,"aigc_audittype":1,"trace_id":"","creative_me