 40964,\n        \"lastDeliveryStatus\": \"unknown\",\n        \"consecutiveErrors\": 10,\n        \"lastError\": \"Delivering to Feishu requires target <chatId|user:openId|chat:chatId>\"\n      }\n    },\n    {\n      \"id\": \"1dc22710-ba22-49c2-b438-b34ae6829d80\",\n      \"agentId\": \"main\",\n      \"sessionKey\": \"agent:main:main\",\n      \"name\": \"OpenClaw Daily Backup\",\n      \"enabled\": true,\n      \"createdAtMs\": 1773717198868,\n      \"updatedAtMs\": 1773717198868,\n      \"schedule\": {\n        \"kind\": \"cron\",\n        \"expr\": \"0 2 * * *\",\n        \"tz\": \"Asia/Shanghai\"\n      },\n      \"sessionTarget\": \"isolated\",\n      \"wakeMode\": \"now\",\n      \"payload\": {\n        \"kind\": \"agentTurn\",\n        \"message\": \"执行 OpenClaw 自动备份任务：\\n1. 备份 C:\\\\Users\\\\Administrator\\\\.openclaw 到 D:\\\\openclaw-backup-$(Get-Date -Format 'yyyy-MM-dd')\\n2. 使用 robocopy 复制文件（排除 node_modules 和 .git）\\n3. 初始化 git 仓库并提交\\n4. 推送到 GitHub 仓库 https://github.com/SUPPAN550/openclaw 的分支 backups/$(Get-Date -Format 'yyyy-MM-dd')\\n5. 使用 Token: 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\\n6. 完成后发送确认消息\\n\\n注意：如果分支已存在，需要先拉取或创建新分支名（可加时间戳）\",\n        \"timeoutSeconds\": 300\n      },\n      \"delivery\": {\n        \"mode\": \"announce\",\n        \"channel\": \"webchat\"\n      },\n      \"state\": {\n        \"nextRunAtMs\": 1773770400000\n      }\n    },\n    {\n      \"id\": \"22b11d92-3bbb-442b-b50c-267c1b59104c\",\n      \"agentId\": \"main\",\n      \"sessionKey\": \"agent:main:main\",\n      \"name\": \"Tiger: 安全扫描\",\n      \"enabled\": true,\n      \"createdAtMs\": 1773760308124,\n      \"updatedAtMs\": 1773760308124,\n      \"schedule\": {\n        \"kind\": \"cron\",\n        \"expr\": \"0 3 * * *\",\n        \"tz\": \"Asia/Shanghai\"\n      },\n      \"sessionTarget\": \"isolated\",\n      \"wakeMode\": \"now\",\n      \"payload\": {\n        \"kind\": \"agentTurn\",\n        \"message\": \"你是 Tiger（安全更新），执行每日安全扫描：\\n1. 检查 OpenClaw 是否有新版本\\n2. 检查已安装技能是否有更新\\n3. 确认备份状态\\n4. 发送安全状态摘要\"\n      },\n      \"delivery\": {\n        \"mode\": \"announce\"\n      },\n      \"state\": {\n        \"nextRunAtMs\": 1773774000000\n      }\n    },\n    {\n      \"id\": \"61e73340-3b1d-4b92-a0ab-21c0e42f4a37\",\n      \"agentId\": \"main\",\n      \"sessionKey\": \"agent:main:main\",\n      \"name\": \"Daily Gateway Restart - 5:00 AM\",\n      \"enabled\": true,\n      \"createdAtMs\": 1773736927676,\n      \"updatedAtMs\": 1773736927676,\n      \"schedule\": {\n        \"kind\": \"cron\",\n        \"expr\": \"0 5 * * *\",\n        \"tz\": \"Asia/Shanghai\"\n      },\n      \"sessionTarget\": \"main\",\n      \"wakeMode\": \"now\",\n      \"payload\": {\n        \"kind\": \"systemEvent\",\n        \"text\": \"每日自动重启 Gateway。请执行：openclaw gateway stop && sleep 5 && openclaw gateway start\"\n      },\n      \"state\": {\n        \"nextRunAtMs\": 1773781200000\n      }\n    },\n    {\n      \"id\": \"07780d7d-3430-46aa-8819-9030f1c25cb8\",\n      \"agentId\": \"main\",\n      \"sessionKey\": \"agent:main:main\",\n      \"name\": \"Otter: 日程提醒检查\",\n      \"enabled\": true,\n      \"createdAtMs\": 1773760308101,\n      \"updatedAtMs\": 1773760308101,\n      \"schedule\": {\n        \"kind\": \"cron\",\n        \"expr\": \"0 7 * * *\",\n        \"tz\": \"Asia/Shanghai\"\n      },\n      \"sessionTarget\": \"isolated\",\n      \"wakeMode\": \"now\",\n      \"payload\": {\n        \"kind\": \"agentTurn\",\n        \"message\": \"你是 Otter（私人助理），检查今天的飞书日历和任务：\\n1. 获取今日日程\\n2. 列出待办事项\\n3. 发送今日行程概览给用户\"\n      },\n      \"delivery\": {\n        \"mode\": \"announce\"\n      },\n      \"state\": {\n        \"nextRunAtMs\": 1773788400000\n      }\n    },\n    {\n      \"id\": \"1be3234d-b25c-4860-94ca-411343a4a3e9\",\n      \"agentId\": \"main\",\n      \"sessionKey\": \"agent:main:main\",\n      \"name\": \"Gock: 早间新闻简报\",\n      \"enabled\": true,\n      \"createdAtMs\": 1773760308080,\n      \"updatedAtMs\": 1773760308080,\n      \"schedule\": {\n        \"kind\": \"cron\",\n        \"expr\": \"0 8 * * *\",\n        \"tz\": \"Asia/Shanghai\"\n      },\n      \"sessionTarget\": \"isolated\",\n      \"wakeMode\": \"now\",\n      \"payload\": {\n        \"kind\": \"agentTurn\",\n        \"message\": \"你是 Gock（每日新闻），使用 news-summary skill 获取今日新闻，生成一份简洁的早间新闻简报（科技、财经、国际要点），发送给用户\"\n      },\n      \"delivery\": {\n        \"mode\": \"announce\"\n      },\n      \"state\": {\n        \"nextRunAtMs\": 1773792000000\n      }\n    },\n    {\n      \"id\": \"bcd5d811-787e-4d9a-852c-8c4555613fc0\",\n      \"agentId\": \"main\",\n      \"sessionKey\": \"agent:main:feishu:group:oc_71ff41fed588e906f6fa6b786920c244\",\n      \"name\": \"每日新闻推送 - 9:00 AM\",\n      \"enabled\": true,\n      \"createdAtMs\": 1773679699299,\n      \"updatedAtMs\": 1773712513797,\n      \"schedule\": {\n        \"kind\": \"cron\",\n        \"expr\": \"0 9 * * *\",\n        \"tz\": \"Asia/Shanghai\"\n      },\n      \"sessionTarget\": \"isolated\",\n      \"wakeMode\": \"now\",\n      \"payload\": {\n        \"kind\": \"agentTurn\",\n        \"message\": \"获取今日国际新闻摘要并推送给用户。使用 news-summary 技能从 BBC、Reuters 等 RSS 源获取最新新闻，生成简洁的中文摘要（5-8条重要新闻），按类别分组（国际、商业、科技等），然后直接推送给用户。格式：\\n\\n📰 今日新闻摘要 [日期]\\n\\n🌍 国际\\n- [新闻1]\\n- [新闻2]\\n\\n💼 商业\\n- [新闻1]\\n\\n💻 科技\\n- [新闻1]\\n\\n来源：BBC、Reuters 等\"\n      },\n      \"delivery\": {\n        \"mode\": \"announce\",\n        \"to\": \"oc_71ff41fed588e906f6fa6b786920c244\",\n        \"channel\": \"feishu\"\n      },\n      \"state\": {\n        \"nextRunAtMs\": 1773795600000,\n        \"lastRunAtMs\": 1773712441355,\n        \"lastRunStatus\": \"ok\",\n        \"lastStatus\": \"ok\",\n        \"lastDurationMs\": 72442,\n        \"lastDelivered\": true,\n        \"lastDeliveryStatus\": \"delivered\",\n        \"consecutiveErrors\": 0\n      }\n    },\n    {\n      \"id\": \"02249a0e-7ce4-4be3-b1ef-f04f17e0ddb5\",\n      \"agentId\": \"main\",\n   