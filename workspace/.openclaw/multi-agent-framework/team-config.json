    },
    {
      "id": "otter",
      "name": "Otter",
      "animal": "🦦",
      "role": "assistant",
      "type": "persistent",
      "model": "moonshot/kimi-k2.5",
      "priority": 2,
      "schedule": "always",
      "channels": ["telegram"]
    },
    {
      "id": "pandas",
      "name": "Pandas",
      "animal": "🐼",
      "role": "developer",
      "type": "persistent",
      "model": "deepseek/deepseek-chat",
      "priority": 3,
      "schedule": "always",
      "channels": ["telegram", "web"]
    },
    {
      "id": "monkey",
      "name": "Monkey",
      "animal": "🐵",
      "role": "content",
      "type": "triggered",
      "model": "moonshot/kimi-k2.5",
      "priority": 3,
      "schedule": "on-demand",
      "channels": ["telegram"]
    },
    {
      "id": "tiger",
      "name": "Tiger",
      "animal": "🐯",
