# OpenClaw Control Center Environment Variables

# OpenClaw Gateway API URL
# Leave empty or set to empty string to use mock data
VITE_OPENCLAW_API_URL=

# Use mock data instead of real API (true/false)
VITE_USE_MOCK_DATA=true

# OpenClaw WebSocket URL
VITE_OPENCLAW_WS_URL=

# Optional: API Authentication Token
# VITE_OPENCLAW_TOKEN=your_token_here
