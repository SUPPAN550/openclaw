{"type":"message","id":"e2b050fc","parentId":"94b5c198","timestamp":"2026-03-17T03:35:27.685Z","message":{"role":"toolResult","toolCallId":"read:44","toolName":"read","content":[{"type":"text","text":"/**\n * OpenClaw Hub - Agent Matrix 主应用脚本\n * 功能：系统状态监控、Agent 管理、快速控制\n * 修改：连接真实后端 API 获取数据\n */\n\n// ===== API 配置 =====\nconst API_BASE_URL = 'http://127.0.0.1:5000/api';\n\n// ===== Agent 默认配置（用于补充信息）=====\nconst AGENTS_CONFIG = [\n    {\n        id: 'main',\n        name: 'main',\n        displayName: 'Main',\n        role: '主代理',\n        description: '核心主代理，负责协调和管理其他 Agent 的工作流程',\n        icon: 'fa-robot',\n        color: '#6366f1'\n    },\n    {\n        id: 'coder',\n        name: 'coder',\n        displayName: 'Coder',\n        role: '编程助手',\n        description: '专业编程助手，协助代码编写、调试和代码审查',\n        icon: 'fa-code',\n        color: '#06b6d4'\n    },\n    {\n        id: 'researcher',\n        name: 'researcher',\n        displayName: 'Researcher',\n        role: '研究助手',\n        description: '研究助手，负责信息收集、分析和研究报告生成',\n        icon: 'fa-search',\n        color: '#8b5cf6'\n    },\n    {\n        id: 'evolution',\n        name: 'evolution',\n        displayName: 'Evolution',\n        role: '进化/学习',\n        description: '进化学习 Agent，持续优化和自我改进',\n        icon: 'fa-dna',\n        color: '#10b981'\n    },\n    {\n        id: 'sysadmin',\n        name: 'sysadmin',\n        displayName: 'SysAdmin',\n        role: '系统管理',\n        description: '系统管理专家，负责服务器维护和系统配置',\n        icon: 'fa-server',\n        color: '#f59e0b'\n    },\n    {\n        id: 'coordinator',\n        name: 'coordinator',\n        displayName: 'Coordinator',\n        role: '协调器',\n        description: '任务协调器，管理和分配任务给各个 Agent',\n        icon: 'fa-project-diagram',\n        color: '#ec4899'\n    },\n    {\n        id: 'security',\n        name: 'security',\n        displayName: 'Security',\n        role: '安全',\n        description: '安全专家，负责系统安全和漏洞检测',\n        icon: 'fa-shield-alt',\n        color: '#ef4444'\n    },\n    {\n        id: 'wechat',\n        name: 'wechat',\n        displayName: 'WeChat',\n        role: '微信集成',\n        description: '微信集成 Agent，处理微信消息和通知',\n        icon: 'fa-comments',\n        color: '#22c55e'\n    },\n    {\n        id: 'analyst',\n        name: 'analyst',\n        displayName: 'Analyst',\n        role: '分析',\n        description: '数据分析专家，提供数据洞察和可视化',\n        icon: 'fa-chart-line',\n        color: '#3b82f6'\n    },\n    {\n        id: 'ppt-writer',\n        name: 'ppt-writer',\n        displayName: 'PPT Writer',\n        role: 'PPT 生成',\n        description: 'PPT 生成助手，快速创建专业演示文稿',\n        icon: 'fa-file-powerpoint',\n        color: '#f97316'\n    },\n    {\n        id: 'vision',\n        name: 'vision',\n        displayName: 'Vision',\n        role: '视觉',\n        description: '视觉处理 Agent，图像识别和视觉分析',\n        icon: 'fa-eye',\n        color: '#a855f7'\n    }\n];\n\n// ===== 全局状态 =====\nlet agentsData = [];\nlet currentAgent = null;\nlet systemStatsInterval = null;\nlet agentsRefreshInterval = null;\n\n// ===== 初始化 =====\ndocument.addEventListener('DOMContentLoaded', () => {\n    initializeApp();\n    bindEvents();\n    startSystemMonitoring();\n    startAgentsMonitoring();\n});\n\n// ===== 初始化应用 =====\nasync function initializeApp() {\n    showNotification('正在连接 OpenClaw Hub...');\n    \n    // 检查后端服务是否可用\n    const health = await checkBackendHealth();\n    if (!health) {\n        showNotification('警告：后端服务未启动，请运行 start.bat', 5000);\n    } else {\n        showNotification('已连接到 OpenClaw Hub 后端');\n    }\n    \n    // 加载 Agent 数据\n    await loadAgents();\n}\n\n// ===== 检查后端健康状态 =====\nasync function checkBackendHealth() {\n    try {\n        const response = await fetch(`${API_BASE_URL}/health`, { \n            method: 'GET',\n            timeout: 3000 \n        });\n        return response.ok;\n    } catch (error) {\n        console.warn('Backend health check failed:', error);\n        return false;\n    }\n}\n\n// ===== 加载 Agent 数据 =====\nasync function loadAgents() {\n    try {\n        const response = await fetch(`${API_BASE_URL}/agents`);\n        const result = await response.json();\n        \n        if (result.success && result.data) {\n            // 合并后端数据与本地配置\n            agentsData = result.data.map(agent => {\n                const config = AGENTS_CONFIG.find(c => c.id === agent.id) || {};\n                return {\n                    ...config,\n                    ...agent,\n                    // 优先使用后端的状态\n                    status: agent.status || config.status || 'offline'\n                };\n            });\n            \n            renderAgentGrid();\n        } else {\n            // 使用默认配置\n            agentsData = AGENTS_CONFIG.map(agent => ({\n                ...agent,\n                status: 'offline',\n                model: 'unknown',\n                sessions: 0\n            }));\n            renderAgentGrid();\n        }\n    } catch (error) {\n        console.error('加载 Agent 数据失败:', error);\n        // 使用默认配置\n        agentsData = AGENTS_CONFIG.map(agent => ({\n            ...agent,\n            status: 'offline',\n            model: 'unknown',\n            sessions: 0\n        }));\n        renderAgentGrid();\n    }\n}\n\n// ===== 渲染 Agent 网格 =====\nfunction renderAgentGrid() {\n    const grid = document.getElementById('agent-grid');\n    if (!grid) return;\n    \n    if (agentsData.length === 0) {\n        grid.innerHTML = '<div class=\"empty-state\">暂无 Agent 数据</div>';\n        return;\n    }\n    \n    grid.innerHTML = agentsData.map(agent => createAgentCard(agent)).join('');\n    \n    // 绑定卡片点击事件\n    document.querySelectorAll('.agent-card').forEach(card => {\n        card.addEventListener('click', (e) => {\n            if (!e.target.closest('.action-btn-small')) {\n                const agentId = card.dataset.agentId;\n                openAgentModal(agentId);\n            }\n        });\n    });\n    \n    // 绑定快速操作按钮\n    document.querySelectorAll('.action-btn-small').forEach(btn => {\n        btn.addEventListener('click', (e) => {\n            e.stopPropagation();\n            const agentId = btn.closest('.agent-card').dataset.agentId;\n            const action = btn.dataset.action;\n            handleAgentAction(agentId, action);\n        });\n    });\n}\n\n// ===== 创建 Agent 卡片 =====\nfunction createAgentCard(agent) {\n    const status = agent.status || 'offline';\n    const model = agent.model || 'unknown';\n    const sessions = agent.sessions || 0;\n    \n    return `\n        <div class=\"agent-card ${status}\" data-agent-id=\"${agent.id}\">\n            <div class=\"agent-header\">\n                <div class=\"agent-avatar\" style=\"background: linear-gradient(135deg, ${agent.color} 0%, ${adjustColor(agent.color, -20)} 100%)\">\n                    <i class=\"fas ${agent.icon}\"></i>\n                    <span class=\"status-indicator ${status}\"></span>\n                </div>\n                <div class=\"agent-info-text\">\n                    <div class=\"agent-name\">${agent.displayName}</div>\n                    <div class=\"agent-role\">${agent.role}</div>\n                    <div class=\"agent-meta\">\n                        <span class=\"model-tag\" title=\"当前模型\">${model}</span>\n                        ${sessions > 0 ? `<span class=\"session-tag\">${sessions} 会话</span>` : ''}\n                    </div>\n                </div>\n            </div>\n            <div class=\"agent-actions-quick\">\n                <button class=\"action-btn-small start\" data-action=\"start\" title=\"启动\">\n                    <i class=\"fas fa-play\"></i>\n                </button>\n                <button class=\"action-btn-small stop\" data-action=\"stop\" title=\"停止\">\n                    <i class=\"fas fa-stop\"></i>\n                </button>\n                <button class=\"action-btn-small restart\" data-action=\"restart\" title=\"重启\">\n                    <i class=\"fas fa-redo\"></i>\n                </button>\n            </div>\n        </div>\n    `;\n}\n\n// ===== 调整颜色亮度 =====\nfunction adjustColor(color, amount) {\n    const num = parseInt(color.replace('#', ''), 16);\n    const r = Math.max(0, Math.min(255, (num >> 16) + amount));\n    const g = Math.max(0, Math.min(255, ((num >> 8) & 0x00FF) + amount));\n    const b = Math.max(0, Math.min(255, (num & 0x00FF) + amount));\n    return `#${((r << 16) | (g << 8) | b).toString(16).padStart(6, '0')}`;\n}\n\n// ===== 打开 Agent 模态框 =====\nfunction openAgentModal(agentId) {\n    const agent = agentsData.find(a => a.id === agentId);\n    if (!agent) return;\n    \n    currentAgent = agent;\n    const status = agent.status || 'offline';\n    \n    document.getElementById('modal-agent-name').textContent = agent.displayName;\n    document.getElementById('modal-agent-desc').textContent = agent.description || '';\n    document.getElementById('modal-avatar').innerHTML = `<i class=\"fas ${agent.icon}\"></i>`;\n    document.getElementById('modal-avatar').style.background = `linear-gradient(135deg, ${agent.color} 0%, ${adjustColor(agent.color, -20)} 100%)`;\n    \n    const statusBadge = document.getElementById('modal-status');\n    statusBadge.className = `status-badge ${status}`;\n    statusBadge.innerHTML = `<span class=\"dot ${status}\"></span> ${getStatusText(status)}`;\n    \n    // 更新日志显示\n    updateAgentLogs(agent);\n    \n    document.getElementById('agent-modal').classList.add('active');\n}\n\n// ===== 更新 Agent 日志 =====\nfunction updateAgentLogs(agent) {\n    const container = document.getElementById('log-container');\n    if (!container) return;\n    \n    const logs = [\n        { time: new Date().toLocaleTimeString('zh-CN'), message: `Agent: ${agent.displayName}` },\n        { time: new Date().toLocaleTimeString('zh-CN'), message: `状态: ${getStatusText(agent.status || 'offline')}` },\n        { time: new Date().toLocaleTimeString('zh-CN'), message: `模型: ${agent.model || 'unknown'}` },\n        { time: new Date().toLocaleTimeString('zh-CN'), message: `会话数: ${agent.sessions || 0}` },\n    ];\n    \n    if (agent.lastActive) {\n        logs.push({ \n            time: new Date().toLocaleTimeString('zh-CN'), \n            message: `最后活跃: ${new Date(agent.lastActive).toLocaleString('zh-CN')}` \n        });\n    }\n    \n    container.innerHTML = logs.map(log => \n        `<div class=\"log-entry\"><span class=\"timestamp\">[${log.time}]</span> ${log.message}</div>`\n    ).join('');\n}\n\n// ===== 关闭模态框 =====\nfunction closeAgentModal() {\n    document.getElementById('agent-modal').classList.remove('active');\n    currentAgent = null;\n}\n\n// ===== 获取状态文本 =====\nfunction getStatusText(status) {\n    const statusMap = {\n        'online': '在线',\n        'offline': '离线',\n        'busy': '忙碌'\n    };\n    return statusMap[status] || status;\n}\n\n// ===== 处理 Agent 操作 =====\nasync function handleAgentAction(agentId, action) {\n    const agent = agentsData.find(a => a.id === agentId);\n    if (!agent) return;\n    \n    showNotification(`${agent.displayName}: ${getActionText(action)}中...`);\n    \n    try {\n        const response = await fetch(`${API_BASE_URL}/agents/${agentId}/${action}`, {\n            method: 'POST',\n            headers: { 'Content-Type': 'application/json' }\n        });\n        \n        const result = await response.json();\n        \n        if (result.success) {\n            // 更新本地状态\n            const agentIndex = agentsData.findIndex(a => a.id === agentId);\n            if (agentIndex !== -1) {\n                switch (action) {\n                    case 'start':\n                        agentsData[agentIndex].status = 'online';\n                        break;\n                    case 'stop':\n                        agentsData[agentIndex].status = 'offline';\n                        break;\n                    case 'restart':\n                        agentsData[agentIndex].status = 'busy';\n                        setTimeout(() => {\n                            agentsData[agentIndex].status = 'online';\n                            renderAgentGrid();\n                        }, 2000);\n                        break;\n                }\n                renderAgentGrid();\n            }\n            \n            showNotification(`${agent.displayName}: ${getActionText(action)}完成`);\n            \n            // 刷新 Agent 状态\n            setTimeout(() => loadAgents(), 1000);\n        } else {\n            showNotification(`${agent.displayName}: ${getActionText(action)}失败 - ${result.error || '未知错误'}`, 5000);\n        }\n    } catch (error) {\n        console.error('Agent 操作失败:', error);\n        showNotification(`${agent.displayName}: ${getActionText(action)}失败 - ${error.message}`, 5000);\n    }\n    \n    if (currentAgent && currentAgent.id === agentId) {\n        openAgentModal(agentId);\n    }\n}\n\n// ===== 获取操作文本 =====\nfunction getActionText(action) {\n    const actionMap = {\n        'start': '启动',\n        'stop': '停止',\n        'restart': '重启'\n    };\n    return actionMap[action] || action;\n}\n\n// ===== 系统监控 =====\nfunction startSystemMonitoring() {\n    updateSystemStats();\n    systemStatsInterval = setInterval(updateSystemStats, 3000);\n}\n\n// ===== Agent 监控 =====\nfunction startAgentsMonitoring() {\n    agentsRefreshInterval = setInterval(loadAgents, 10000); // 每10秒刷新一次\n}\n\n// ===== 更新系统状态 =====\nasync function updateSystemStats() {\n    try {\n        const response = await fetch(`${API_BASE_URL}/system/stats`);\n        const result = await response.json();\n        \n        if (result.success && result.data) {\n            const data = result.data;\n            \n            // 更新 CPU\n            if (data.cpu) {\n                document.getElementById('cpu-usage').textContent = `${data.cpu.usage}%`;\n                document.getElementById('cpu-bar').style.width = `${Math.min(data.cpu.usage, 100)}%`;\n            }\n            \n            // 更新内存\n            if (data.memory) {\n                document.getElementById('memory-usage').textContent = `${data.memory.usage}%`;\n                document.getElementById('memory-bar').style.width = `${Math.min(data.memory.usage, 100)}%`;\n            }\n            \n            // 更新存储\n            if (data.storage) {\n                document.getElementById('storage-usage').textContent = `${data.storage.usage}%`;\n                document.getElementById('storage-bar').style.width = `${Math.min(data.storage.usage, 100)}%`;\n            }\n        }\n    } catch (error) {\n        console.error('更新系统状态失败:', error);\n        // 显示离线状态\n        document.getElementById('cpu-usage').textContent = '--';\n        document.getElementById('memory-usage').textContent = '--';\n        document.getElementById('storage-usage').textContent = '--';\n    }\n}\n\n// ===== 绑定事件 =====\nfunction bindEvents() {\n    // 模态框关闭\n    const closeModalBtn = document.getElementById('close-modal');\n    if (closeModalBtn) {\n        closeModalBtn.addEventListener('click', closeAgentModal);\n    }\n    \n    const modal = document.getElementById('agent-modal');\n    if (modal) {\n        modal.addEventListener('click', (e) => {\n            if (e.target === modal) {\n                closeAgentModal();\n            }\n        });\n    }\n    \n    // 模态框操作按钮\n    const modalStart = document.getElementById('modal-start');\n    const modalStop = document.getElementById('modal-stop');\n    const modalRestart = document.getElementById('modal-restart');\n    const modalChat = document.getElementById('modal-chat');\n    \n    if (modalStart) {\n        modalStart.addEventListener('click', () => {\n            if (currentAgent) handleAgentAction(currentAgent.id, 'start');\n        });\n    }\n    \n    if (modalStop) {\n        modalStop.addEventListener('click', () => {\n            if (currentAgent) handleAgentAction(currentAgent.id, 'stop');\n        });\n    }\n    \n    if (modalRestart) {\n        modalRestart.addEventListener('click', () => {\n            if (currentAgent) handleAgentAction(currentAgent.id, 'restart');\n        });\n    }\n    \n    if (modalChat) {\n        modalChat.addEventListener('click', () => {\n            if (currentAgent) enterChat(currentAgent.id);\n        });\n    }\n    \n    // 快速控制按钮\n    bindControlButton('btn-webui', 'webui', '正在打开 WebUI...', () => {\n        window.open('http://127.0.0.1:18789/', '_blank');\n    });\n    \n    bindControlButton('btn-restart', 'restart', '正在重启 OpenClaw 服务...', null, true);\n    bindControlButton('btn-update', 'update', '正在检查更新...');\n    bindControlButton('btn-repair', 'doctor', '正在运行故障修复...');\n    bindControlButton('btn-sandbox', 'sandbox', '正在切换沙箱模式...', toggleSandboxMode);\n    bindControlButton('btn-stop', 'stop', '正在停止 OpenClaw 服务...', null, true);\n    \n    // 键盘快捷键\n    document.addEventListener('keydown', (e) => {\n        if (e.key === 'Escape') {\n            closeAgentModal();\n        }\n    });\n}\n\n// ===== 绑定控制按钮 =====\nfunction bindControlButton(btnId, action, loadingMessage, customHandler = null, needConfirm = false) {\n    const btn = document.getElementById(btnId);\n    if (!btn) return;\n    \n    btn.addEventListener('click', async () => {\n        if (needConfirm) {\n            const confirmMsg = action === 'stop' \n                ? '确定要停止 OpenClaw 服务吗？' \n                : '确定要重启 OpenClaw 服务吗？';\n            if (!confirm(confirmMsg)) return;\n        }\n        \n        showNotification(loadingMessage);\n        \n        if (customHandler) {\n            await customHandler();\n            return;\n        }\n        \n        try {\n            const response = await fetch(`${API_BASE_URL}/control/${action}`, {\n                method: 'POST',\n                headers: { 'Content-Type': 'application/json' }\n            });\n            \n            const result = await response.json();\n            \n            if (result.success) {\n                showNotification(result.message || '操作完成');\n                \n                // 特殊处理 WebUI\n                if (action === 'webui' && result.url) {\n                    window.open(result.url, '_blank');\n                }\n            } else {\n                showNotification(`操作失败: ${result.error || '未知错误'}`, 5000);\n            }\n        } catch (error) {\n            console.error('控制操作失败:', error);\n            showNotification(`操作失败: ${error.message}`, 5000);\n        }\n    });\n}\n\n// ===== 切换沙箱模式 =====\nasync function toggleSandboxMode() {\n    try {\n        // 先获取当前状态\n        const response = await fetch(`${API_BASE_URL}/sandbox`);\n        const result = await response.json();\n        \n        const currentEnabled = result.success ? result.enabled : false;\n        const newEnabled = !currentEnabled;\n        \n        // 切换状态\n        const toggleResponse = await fetch(`${API_BASE_URL}/sandbox`, {\n            method: 'POST',\n            headers: { 'Content-Type': 'application/json' },\n            body: JSON.stringify({ enabled: newEnabled })\n        });\n        \n        const toggleResult = await toggleResponse.json();\n        \n        if (toggleResult.success) {\n            showNotification(`沙箱模式已${newEnabled ? '启用' : '禁用'}`);\n        } else {\n            showNotification(`切换沙箱模式失败: ${toggleResult.error || '未知错误'}`, 5000);\n        }\n    } catch (error) {\n        console.error('切换沙箱模式失败:', error);\n        showNotification(`切换沙箱模式失败: ${error.message}`, 5000);\n    }\n}\n\n// ===== 进入对话 =====\nfunction enterChat(agentId) {\n    const agent = agentsData.find(a => a.id === agentId);\n    if (!agent) return;\n    \n    showNotification(`正在进入 ${agent.displayName} 对话...`);\n    window.open(`http://127.0.0.1:18789/chat/${agentId}`, '_blank');\n}\n\n// ===== 显示通知 =====\nfunction showNotification(message, duration = 3000) {\n    const notification = document.getElementById('notification');\n    const text = document.getElementById('notification-text');\n    \n    if (!notification || !text) return;\n    \n    text.textContent = message;\n    notification.classList.add('active');\n    \n    setTimeout(() => {\n        notification.classList.remove('active');\n    }, duration);\n}\n\n// ===== 页面卸载时清理 =====\nwindow.addEventListener('beforeunload', () => {\n    if (systemStatsInterval) {\n        clearInterval(systemStatsInterval);\n    }\n    if (agentsRefreshInterval) {\n        clearInterval(agentsRefreshInterval);\n    }\n});\n"}],"isError":false,"timestamp":1773718527682}}
{"type":"message","id":"9aad9710","parentId":"e2b050fc","timestamp":"2026-03-17T03:35:30.910Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"read:45","name":"read","arguments":{"file_path":"C:\\Users\\Administrator\\.openclaw\\workspace\\openclaw-hub\\start.bat"}}],"api":"openai-completions","provider":"moonshot","model":"kimi-k2.5","usage":{"input":5097,"output":35,"cacheRead":48896,"cacheWrite":0,"totalTokens":54028,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773718527686}}
{"type":"message","id":"625e8f93","parentId":"9aad9710","timestamp":"2026-03-17T03:35:30.916Z","message":{"role":"toolResult","toolCallId":"read:45","toolName":"read","content":[{"type":"text","text":"@echo off\nchcp 65001 >nul\ntitle OpenClaw Hub Launcher\necho.\necho  ╔══════════════════════════════════════════════════════════╗\necho  ║                                                          ║\necho  ║              OpenClaw Hub Web Panel                      ║\necho  ║                                                          ║\necho  ╚══════════════════════════════════════════════════════════╝\necho.\n\nREM 检查必要文件\nif not exist \"index.html\" (\n    echo [错误] 未找到 index.html 文件\n    echo 请确保在正确的目录下运行此脚本\n    pause\n    exit /b 1\n)\n\nif not exist \"server.py\" (\n    echo [错误] 未找到 server.py 文件\n    echo 请确保在正确的目录下运行此脚本\n    pause\n    exit /b 1\n)\n\nREM 检查 Python\npython --version >nul 2>&1\nif %errorlevel% neq 0 (\n    echo [错误] 未找到 Python\n    echo 请安装 Python 3.x 并确保已添加到 PATH\n    pause\n    exit /b 1\n)\n\nREM 检查 Flask\necho [信息] 检查依赖...\npython -c \"import flask\" >nul 2>&1\nif %errorlevel% neq 0 (\n    echo [信息] 正在安装 Flask...\n    pip install flask flask-cors psutil\n    if %errorlevel% neq 0 (\n        echo [错误] 安装 Flask 失败\n        pause\n        exit /b 1\n    )\n)\n\nREM 检查 psutil\npython -c \"import psutil\" >nul 2>&1\nif %errorlevel% neq 0 (\n    echo [信息] 正在安装 psutil...\n    pip install psutil\n)\n\nREM 检查 flask-cors\npython -c \"import flask_cors\" >nul 2>&1\nif %errorlevel% neq 0 (\n    echo [信息] 正在安装 flask-cors...\n    pip install flask-cors\n)\n\necho.\necho [信息] 正在启动 OpenClaw Hub...\necho [信息] 后端 API: http://127.0.0.1:5000\necho [信息] 前端面板: http://localhost:8080\necho.\necho 按 Ctrl+C 停止服务\necho.\n\nREM 启动后端服务（在后台）\nstart \"OpenClaw Hub Backend\" cmd /c \"python server.py\"\n\nREM 等待后端启动\ntimeout /t 2 /nobreak >nul\n\nREM 启动前端 HTTP 服务器\necho [模式] 使用 Python HTTP 服务器\necho.\npython -m http.server 8080\n\necho.\necho [信息] 服务器已停止\npause\n"}],"isError":false,"timestamp":1773718530914}}
