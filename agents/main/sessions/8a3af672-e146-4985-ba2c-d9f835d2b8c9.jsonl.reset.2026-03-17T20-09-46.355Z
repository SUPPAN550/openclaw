{"type":"message","id":"0785a658","parentId":"d5b670c1","timestamp":"2026-03-17T15:59:48.817Z","message":{"role":"toolResult","toolCallId":"read:106","toolName":"read","content":[{"type":"text","text":"import axios, { AxiosInstance } from 'axios';\nimport type { \n  Agent, \n  Session, \n  Task, \n  MemoryEntry, \n  Document, \n  UsageStats, \n  SystemStats,\n  GatewayStatus \n} from '../types';\n\n// OpenClaw Gateway API client\nclass OpenClawAPI {\n  private client: AxiosInstance;\n  private baseURL: string;\n\n  private isOnline: boolean = false;\n  private useMockData: boolean = true;\n\n  constructor() {\n    // Default to local gateway, can be configured\n    this.baseURL = import.meta.env.VITE_OPENCLAW_API_URL || 'http://localhost:8080/api';\n    \n    // Check if we should use real API or mock data\n    this.useMockData = import.meta.env.VITE_USE_MOCK_DATA === 'true' || !this.baseURL;\n    \n    this.client = axios.create({\n      baseURL: this.baseURL,\n      timeout: 2000, // Short timeout for faster fallback\n      headers: {\n        'Content-Type': 'application/json',\n      },\n    });\n\n    // Add auth token if available\n    this.client.interceptors.request.use((config) => {\n      const token = localStorage.getItem('openclaw_token');\n      if (token) {\n        config.headers.Authorization = `Bearer ${token}`;\n      }\n      return config;\n    });\n  }\n\n  // Gateway Status\n  async getGatewayStatus(): Promise<GatewayStatus> {\n    if (this.useMockData) {\n      return this.getFallbackGatewayStatus();\n    }\n    \n    try {\n      // Try to get real status from gateway\n      const response = await this.client.get('/status');\n      this.isOnline = true;\n      return response.data;\n    } catch (error) {\n      // Fallback: try to detect if gateway is running\n      this.isOnline = false;\n      return this.getFallbackGatewayStatus();\n\n[281 more lines in file. Use offset=61 to continue.]"}],"isError":false,"timestamp":1773763188812}}
{"type":"message","id":"96220c71","parentId":"0785a658","timestamp":"2026-03-17T15:59:53.921Z","message":{"role":"assistant","content":[{"type":"text","text":"问题是 `.env` 文件中的 `VITE_USE_MOCK_DATA=true` 没有被正确读取。让我检查并修复："},{"type":"toolCall","id":"read:107","name":"read","arguments":{"file_path":"C:/Users/Administrator/.openclaw/workspace/control-center/.env"}}],"api":"openai-completions","provider":"moonshot","model":"kimi-k2.5","usage":{"input":540,"output":55,"cacheRead":142080,"cacheWrite":0,"totalTokens":142675,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773763188819}}
{"type":"message","id":"c425a74e","parentId":"96220c71","timestamp":"2026-03-17T15:59:53.939Z","message":{"role":"toolResult","toolCallId":"read:107","toolName":"read","content":[{"type":"text","text":"# OpenClaw Control Center Environment Variables\n\n# OpenClaw Gateway API URL\n# Leave empty or set to empty string to use mock data\nVITE_OPENCLAW_API_URL=\n\n# Use mock data instead of real API (true/false)\nVITE_USE_MOCK_DATA=true\n\n# OpenClaw WebSocket URL\nVITE_OPENCLAW_WS_URL=\n\n# Optional: API Authentication Token\n# VITE_OPENCLAW_TOKEN=your_token_here\n"}],"isError":false,"timestamp":1773763193934}}
