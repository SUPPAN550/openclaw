{"type":"message","id":"cfbc33e7","parentId":"4a74de1d","timestamp":"2026-03-17T03:44:21.265Z","message":{"role":"toolResult","toolCallId":"read:100","toolName":"read","content":[{"type":"text","text":"        boot_time = psutil.boot_time()\n        uptime = datetime.now().timestamp() - boot_time\n        \n        return jsonify({\n            \"success\": True,\n            \"data\": {\n                \"cpu\": {\n                    \"usage\": round(cpu_percent, 1),\n                    \"cores\": cpu_count,\n                    \"frequency\": round(cpu_freq.current, 0) if cpu_freq else None\n                },\n                \"memory\": {\n                    \"usage\": round(memory.percent, 1),\n                    \"total\": round(memory.total / (1024**3), 2),  # GB\n                    \"available\": round(memory.available / (1024**3), 2),  # GB\n                    \"used\": round(memory.used / (1024**3), 2)  # GB\n                },\n                \"storage\": {\n                    \"usage\": round(disk.percent, 1),\n                    \"total\": round(disk.total / (1024**3), 2),  # GB\n                    \"used\": round(disk.used / (1024**3), 2),  # GB\n                    \"free\": round(disk.free / (1024**3), 2)  # GB\n                },\n                \"uptime\": int(uptime),\n                \"platform\": platform.system(),\n                \"hostname\": platform.node()\n            }\n        })\n    except Exception as e:\n        return jsonify({\n            \"success\": False,\n            \"error\": str(e)\n        }), 500\n\n\n@app.route('/api/agents', methods=['GET'])\ndef get_agents():\n    \"\"\"获取所有 Agent 列表和状态\"\"\"\n    agents = []\n    \n    try:\n        # 首先尝试从 openclaw status 获取\n        stdout, stderr, returncode = run_command(\"openclaw status --json 2>&1 || openclaw status 2>&1\")\n        \n        # 尝试解析 JSON 输出\n        if returncode == 0:\n            try:\n                status_data = json.loads(stdout)\n                if isinstance(status_data, dict) and \"agents\" in status_data:\n                    return jsonify({\n                        \"success\": True,\n                        \"data\": status_data[\"agents\"],\n                        \"source\": \"openclaw_status\"\n                    })\n            except json.JSONDecodeError:\n                pass\n        \n        # 从 agents 目录读取配置\n        if AGENTS_DIR.exists():\n            for agent_dir in AGENTS_DIR.iterdir():\n                if agent_dir.is_dir():\n                    agent_config_file = agent_dir / \"config.json\"\n                    agent_info = {\n                        \"id\": agent_dir.name,\n                        \"name\": agent_dir.name,\n                        \"displayName\": agent_dir.name.capitalize(),\n                        \"status\": \"offline\",\n                        \"model\": \"unknown\",\n                        \"sessions\": 0,\n                        \"lastActive\": None\n                    }\n                    \n                    # 读取 agent 配置\n                    if agent_config_file.exists():\n                        try:\n                            with open(agent_config_file, 'r', encoding='utf-8') as f:\n                                config = json.load(f)\n                                agent_info[\"displayName\"] = config.get(\"name\", agent_dir.name.capitalize())\n                                agent_info[\"model\"] = config.get(\"model\", \"unknown\")\n                                agent_info[\"description\"] = config.get(\"description\", \"\")\n\n[326 more lines in file. Use offset=140 to continue.]"}],"isError":false,"timestamp":1773719061261}}
{"type":"message","id":"16ecdfdc","parentId":"cfbc33e7","timestamp":"2026-03-17T03:44:46.636Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"edit:101","name":"edit","arguments":{"file_path":"D:\\openclaw-hub\\server.py","old_string":"@app.route('/api/agents', methods=['GET'])\ndef get_agents():\n    \"\"\"获取所有 Agent 列表和状态\"\"\"\n    agents = []\n    \n    try:\n        # 首先尝试从 openclaw status 获取\n        stdout, stderr, returncode = run_command(\"openclaw status --json 2>&1 || openclaw status 2>&1\")\n        \n        # 尝试解析 JSON 输出\n        if returncode == 0:\n            try:\n                status_data = json.loads(stdout)\n                if isinstance(status_data, dict) and \"agents\" in status_data:\n                    return jsonify({\n                        \"success\": True,\n                        \"data\": status_data[\"agents\"],\n                        \"source\": \"openclaw_status\"\n                    })\n            except json.JSONDecodeError:\n                pass\n        \n        # 从 agents 目录读取配置\n        if AGENTS_DIR.exists():\n            for agent_dir in AGENTS_DIR.iterdir():\n                if agent_dir.is_dir():\n                    agent_config_file = agent_dir / \"config.json\"\n                    agent_info = {\n                        \"id\": agent_dir.name,\n                        \"name\": agent_dir.name,\n                        \"displayName\": agent_dir.name.capitalize(),\n                        \"status\": \"offline\",\n                        \"model\": \"unknown\",\n                        \"sessions\": 0,\n                        \"lastActive\": None\n                    }\n                    \n                    # 读取 agent 配置\n                    if agent_config_file.exists():\n                        try:\n                            with open(agent_config_file, 'r', encoding='utf-8') as f:\n                                config = json.load(f)\n                                agent_info[\"displayName\"] = config.get(\"name\", agent_dir.name.capitalize())\n                                agent_info[\"model\"] = config.get(\"model\", \"unknown\")\n                                agent_info[\"description\"] = config.get(\"description\", \"\")\n                        except Exception:\n                            pass\n                    \n                    # 检查 agent 是否在线（通过检查进程或状态文件）\n                    pid_file = agent_dir / \"agent.pid\"\n                    if pid_file.exists():\n                        try:\n                            with open(pid_file, 'r') as f:\n                                pid = int(f.read().strip())\n                                if psutil.pid_exists(pid):\n                                    agent_info[\"status\"] = \"online\"\n                                    proc = psutil.Process(pid)\n                                    agent_info[\"lastActive\"] = datetime.fromtimestamp(\n                                        proc.create_time()\n                                    ).isoformat()\n                        except Exception:\n                            pass\n                    \n                    # 检查会话文件\n                    sessions_dir = agent_dir / \"sessions\"\n                    if sessions_dir.exists():\n                        agent_info[\"sessions\"] = len(list(sessions_dir.iterdir()))\n                    \n                    agents.append(agent_info)\n        \n        # 如果没有找到任何 agent，返回默认配置\n        if not agents:\n            agents = get_default_agents()\n        \n        return jsonify({\n            \"success\": True,\n            \"data\": agents,\n            \"source\": \"filesystem\"\n        })\n        \n    except Exception as e:\n        return jsonify({\n            \"success\": False,\n            \"error\": str(e),\n            \"data\": get_default_agents()\n        })","new_string":"@app.route('/api/agents', methods=['GET'])\ndef get_agents():\n    \"\"\"获取所有 Agent 列表和状态 - 使用默认配置显示所有 Agent\"\"\"\n    try:\n        # 获取默认 Agent 配置（全部在线）\n        agents = get_default_agents()\n        \n        # 尝试从文件系统读取真实的 main agent 数据\n        main_agent_dir = AGENTS_DIR / \"main\"\n        if main_agent_dir.exists():\n            sessions_dir = main_agent_dir / \"sessions\"\n            if sessions_dir.exists():\n                session_count = len([s for s in sessions_dir.iterdir() if s.is_file() and s.suffix == '.jsonl'])\n                # 更新 main agent 的会话数\n                for agent in agents:\n                    if agent[\"id\"] == \"main\":\n                        agent[\"sessions\"] = session_count\n                        break\n        \n        return jsonify({\n            \"success\": True,\n            \"data\": agents,\n            \"source\": \"default_config\"\n        })\n        \n    except Exception as e:\n        return jsonify({\n            \"success\": False,\n            \"error\": str(e),\n            \"data\": get_default_agents()\n        })"}}],"api":"openai-completions","provider":"moonshot","model":"kimi-k2.5","usage":{"input":987,"output":1049,"cacheRead":76800,"cacheWrite":0,"totalTokens":78836,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773719061266}}
