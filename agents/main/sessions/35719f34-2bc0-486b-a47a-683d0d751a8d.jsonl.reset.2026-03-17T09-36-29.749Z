{"type":"message","id":"7f66b3e1","parentId":"a2dd287c","timestamp":"2026-03-17T08:20:52.469Z","message":{"role":"assistant","content":[{"type":"text","text":"只有 Bash 脚本，没有 PowerShell 版本。我需要创建一个 PowerShell 版本的脚本。让我创建一个简化但可用的 PowerShell 版本：只有 Linux Bash 脚本。让我创建一个 PowerShell 版本："},{"type":"toolCall","id":"write:87","name":"write","arguments":{"content":"# Context Monitor for Windows\n# Monitors OpenClaw session context usage and alerts when threshold is reached\n\nparam(\n    [int]$Threshold = 60,\n    [string]$LogDir = \"$env:USERPROFILE\\.openclaw\\workspace\\logs\",\n    [string]$LogFile = \"$LogDir\\context-monitor.log\"\n)\n\n# Ensure log directory exists\nif (!(Test-Path $LogDir)) {\n    New-Item -ItemType Directory -Path $LogDir -Force | Out-Null\n}\n\nfunction Write-Log($Message) {\n    $timestamp = Get-Date -Format \"yyyy-MM-dd HH:mm:ss\"\n    \"$timestamp - $Message\" | Out-File -Append -FilePath $LogFile\n    Write-Host \"$timestamp - $Message\"\n}\n\n# Get session status using openclaw status\ntry {\n    $statusOutput = & openclaw status 2>&1\n    \n    # Parse context usage from status output\n    # Look for pattern like \"62% (158k/256k)\" in the output\n    $usageMatch = $statusOutput | Select-String -Pattern '(\\d+)%\\s*\\(([^)]+)\\)'\n    \n    if ($usageMatch) {\n        $usage = [int]$usageMatch.Matches[0].Groups[1].Value\n        $details = $usageMatch.Matches[0].Groups[2].Value\n        \n        Write-Log \"Context usage: ${usage}% ($details)\"\n        \n        if ($usage -ge $Threshold) {\n            Write-Log \"WARNING: Context usage ${usage}% exceeds threshold ${Threshold}%\"\n            \n            # Create memory summary\n            $memoryDir = \"$env:USERPROFILE\\.openclaw\\workspace\\memory\"\n            $memoryLite = \"$memoryDir\\MEMORY-LITE.md\"\n            \n            if (Test-Path $memoryLite) {\n                $content = Get-Content $memoryLite -Raw -ErrorAction SilentlyContinue\n                $wordCount = ($content -split '\\s+').Count\n                Write-Log \"MEMORY-LITE.md: $wordCount words\"\n            }\n            \n            # Alert user\n            Write-Log \"ALERT: Consider starting a new session to reset context\"\n        } else {\n            Write-Log \"Context usage normal: ${usage}%\"\n        }\n    } else {\n        Write-Log \"Could not parse context usage from status output\"\n    }\n} catch {\n    Write-Log \"Error checking context: $_\"\n}\n","path":"C:\\Users\\Administrator\\.openclaw\\workspace\\skills\\miliger-context-manager\\scripts\\context-monitor.ps1"}}],"api":"openai-completions","provider":"moonshot","model":"kimi-k2.5","usage":{"input":342,"output":653,"cacheRead":98816,"cacheWrite":0,"totalTokens":99811,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773735631829}}
