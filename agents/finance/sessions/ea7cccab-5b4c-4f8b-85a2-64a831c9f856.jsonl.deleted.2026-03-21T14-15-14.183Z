{"type":"message","id":"acc25891","parentId":"2f6303cf","timestamp":"2026-03-21T13:23:59.340Z","message":{"role":"toolResult","toolCallId":"call_function_qrfqftc6fyqk_1","toolName":"read","content":[{"type":"text","text":"# TradingAgents/graph/setup.py\r\n\r\nfrom typing import Dict, Any, List, Optional\r\nfrom langchain_openai import ChatOpenAI\r\nfrom langgraph.graph import END, StateGraph, START\r\nfrom langgraph.prebuilt import ToolNode\r\n\r\nfrom tradingagents.agents import *\r\nfrom tradingagents.agents.utils.agent_states import AgentState\r\n\r\nfrom .conditional_logic import ConditionalLogic\r\n\r\n\r\nclass GraphSetup:\r\n    \"\"\"Handles the setup and configuration of the agent graph.\"\"\"\r\n\r\n    def __init__(\r\n        self,\r\n        quick_thinking_llm: ChatOpenAI,\r\n        deep_thinking_llm: ChatOpenAI,\r\n        tool_nodes: Dict[str, ToolNode],\r\n        bull_memory,\r\n        bear_memory,\r\n        trader_memory,\r\n        invest_judge_memory,\r\n        risk_manager_memory,\r\n        conditional_logic: ConditionalLogic,\r\n        data_collector=None,\r\n    ):\r\n        \"\"\"Initialize with required components.\"\"\"\r\n        self.quick_thinking_llm = quick_thinking_llm\r\n        self.deep_thinking_llm = deep_thinking_llm\r\n        self.tool_nodes = tool_nodes\r\n        self.bull_memory = bull_memory\r\n        self.bear_memory = bear_memory\r\n        self.trader_memory = trader_memory\r\n        self.invest_judge_memory = invest_judge_memory\r\n        self.risk_manager_memory = risk_manager_memory\r\n        self.conditional_logic = conditional_logic\r\n        self.data_collector = data_collector\r\n\r\n    def setup_graph(\r\n        self, selected_analysts=[\"market\", \"social\", \"sentiment\", \"news\", \"fundamentals\", \"macro\", \"smart_money\", \"game_theory\"],\r\n        checkpointer=None\r\n    ):\r\n        \"\"\"Set up and compile the agent workflow graph.\r\n\r\n        Args:\r\n            selected_analysts (list): List of analyst types to include. Options are:\r\n                - \"market\": Market analyst\r\n\n[206 more lines in file. Use offset=51 to continue.]"}],"isError":false,"timestamp":1774099439337}}
