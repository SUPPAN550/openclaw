{"type":"message","id":"ef766b73","parentId":"97571f62","timestamp":"2026-03-17T08:21:35.777Z","message":{"role":"toolResult","toolCallId":"read:91","toolName":"read","content":[{"type":"text","text":"# Context Monitor for Windows\n# Monitors OpenClaw session context usage and alerts when threshold is reached\n\nparam(\n    [int]$Threshold = 60,\n    [string]$LogDir = \"$env:USERPROFILE\\.openclaw\\workspace\\logs\",\n    [string]$LogFile = \"$LogDir\\context-monitor.log\"\n)\n\n# Ensure log directory exists\nif (!(Test-Path $LogDir)) {\n    New-Item -ItemType Directory -Path $LogDir -Force | Out-Null\n}\n\nfunction Write-Log($Message) {\n    $timestamp = Get-Date -Format \"yyyy-MM-dd HH:mm:ss\"\n    \"$timestamp - $Message\" | Out-File -Append -FilePath $LogFile\n    Write-Host \"$timestamp - $Message\"\n}\n\n# Get session status using openclaw status\ntry {\n    $statusOutput = & openclaw status 2>&1\n    \n    # Parse context usage from status output\n    # Look for pattern like \"62% (158k/256k)\" in the output\n    $usageMatch = $statusOutput | Select-String -Pattern '(\\d+)%\\s*\\(([^)]+)\\)'\n    \n    if ($usageMatch) {\n        $usage = [int]$usageMatch.Matches[0].Groups[1].Value\n        $details = $usageMatch.Matches[0].Groups[2].Value\n        \n        Write-Log \"Context usage: ${usage}% ($details)\"\n        \n        if ($usage -ge $Threshold) {\n            Write-Log \"WARNING: Context usage ${usage}% exceeds threshold ${Threshold}%\"\n            \n            # Create memory summary\n            $memoryDir = \"$env:USERPROFILE\\.openclaw\\workspace\\memory\"\n            $memoryLite = \"$memoryDir\\MEMORY-LITE.md\"\n            \n            if (Test-Path $memoryLite) {\n                $content = Get-Content $memoryLite -Raw -ErrorAction SilentlyContinue\n                $wordCount = ($content -split '\\s+').Count\n                Write-Log \"MEMORY-LITE.md: $wordCount words\"\n            }\n            \n            # Alert user\n            Write-Log \"ALERT: Consider starting a new session to reset context\"\n        } else {\n            Write-Log \"Context usage normal: ${usage}%\"\n        }\n    } else {\n        Write-Log \"Could not parse context usage from status output\"\n    }\n} catch {\n    Write-Log \"Error checking context: $_\"\n}\n"}],"isError":false,"timestamp":1773735695775}}
{"type":"message","id":"900776a0","parentId":"ef766b73","timestamp":"2026-03-17T08:22:04.522Z","message":{"role":"assistant","content":[{"type":"text","text":"问题是 openclaw status 的输出格式不包含上下文使用率信息。我需要使用其他方法来获取这个信息。\n\n实际上，我应该使用 sessions_list 或直接读取会话存储文件来获取上下文使用率。让我修改脚本使用 sessions_list 命令。让我修改脚本使用 sessions_list："},{"type":"toolCall","id":"edit:92","name":"edit","arguments":{"file_path":"C:\\Users\\Administrator\\.openclaw\\workspace\\skills\\miliger-context-manager\\scripts\\context-monitor.ps1","old_string":"# Get session status using openclaw status\ntry {\n    $statusOutput = & openclaw status 2>&1\n    \n    # Parse context usage from status output\n    # Look for pattern like \"62% (158k/256k)\" in the output\n    $usageMatch = $statusOutput | Select-String -Pattern '(\\d+)%\\s*\\(([^)]+)\\)'\n    \n    if ($usageMatch) {\n        $usage = [int]$usageMatch.Matches[0].Groups[1].Value\n        $details = $usageMatch.Matches[0].Groups[2].Value\n        \n        Write-Log \"Context usage: ${usage}% ($details)\"\n        \n        if ($usage -ge $Threshold) {\n            Write-Log \"WARNING: Context usage ${usage}% exceeds threshold ${Threshold}%\"\n            \n            # Create memory summary\n            $memoryDir = \"$env:USERPROFILE\\.openclaw\\workspace\\memory\"\n            $memoryLite = \"$memoryDir\\MEMORY-LITE.md\"\n            \n            if (Test-Path $memoryLite) {\n                $content = Get-Content $memoryLite -Raw -ErrorAction SilentlyContinue\n                $wordCount = ($content -split '\\s+').Count\n                Write-Log \"MEMORY-LITE.md: $wordCount words\"\n            }\n            \n            # Alert user\n            Write-Log \"ALERT: Consider starting a new session to reset context\"\n        } else {\n            Write-Log \"Context usage normal: ${usage}%\"\n        }\n    } else {\n        Write-Log \"Could not parse context usage from status output\"\n    }\n} catch {\n    Write-Log \"Error checking context: $_\"\n}","new_string":"# Get session list to check context usage\ntry {\n    $sessionsOutput = & openclaw sessions list --limit 5 2>&1\n    \n    # Parse session info - look for main session with token usage\n    $mainSession = $sessionsOutput | Select-String -Pattern 'main.*?(\\d+)k.*?(\\d+)k'\n    \n    if ($mainSession) {\n        $used = [int]$mainSession.Matches[0].Groups[1].Value\n        $total = [int]$mainSession.Matches[0].Groups[2].Value\n        $usage = [math]::Round(($used / $total) * 100)\n        \n        Write-Log \"Context usage: ${usage}% (${used}k/${total}k)\"\n        \n        if ($usage -ge $Threshold) {\n            Write-Log \"WARNING: Context usage ${usage}% exceeds threshold ${Threshold}%\"\n            \n            # Check memory files\n            $memoryDir = \"$env:USERPROFILE\\.openclaw\\workspace\\memory\"\n            $memoryLite = \"$memoryDir\\MEMORY-LITE.md\"\n            \n            if (Test-Path $memoryLite) {\n                $content = Get-Content $memoryLite -Raw -ErrorAction SilentlyContinue\n                $wordCount = ($content -split '\\s+').Count\n                Write-Log \"MEMORY-LITE.md: $wordCount words\"\n            }\n            \n            Write-Log \"ALERT: Consider starting a new session to reset context\"\n        } else {\n            Write-Log \"Context usage normal: ${usage}%\"\n        }\n    } else {\n        Write-Log \"Could not find main session context info\"\n    }\n} catch {\n    Write-Log \"Error checking context: $_\"\n}"}}],"api":"openai-completions","provider":"moonshot","model":"kimi-k2.5","usage":{"input":807,"output":893,"cacheRead":100352,"cacheWrite":0,"totalTokens":102052,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773735695778}}
